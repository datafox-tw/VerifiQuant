  {
    "id": "ensure_quick_assets_reasonable",
    "name": "Adjust Inventories for Realistic Quick Assets",
    "short_description": "Adjusts inventory levels to ensure that quick assets (Current Assets minus Inventories and Prepaid Expenses) remain positive or within a realistic range by capping inventories and prepaid expenses to a percentage of current assets.",
    "domain": "Financial Ratios",
    "topic": "Liquidity Ratios",
    "inputs": [
      {
        "name": "ca",
        "type": "integer",
        "description": "Total Current Assets"
      },
      {
        "name": "inv",
        "type": "integer",
        "description": "Inventories"
      },
      {
        "name": "prepaids",
        "type": "integer",
        "description": "Prepaid Expenses"
      }
    ],
    "output_var": "adjusted_inv",
    "sympy_formulas": [
      {
        "variable": "max_inv_pre_limit",
        "formula": "0.85 * ca"
      },
      {
        "variable": "adjusted_inv",
        "formula": "Piecewise((Max(0, max_inv_pre_limit - prepaids), (inv + prepaids) > max_inv_pre_limit), (inv, True))"
      }
    ],
    "tags": [
      "liqratio",
      "liquidity_ratios",
      "inventories",
      "quick_assets",
      "scenario_generation",
      "data_validation"
    ]
  },
  {
    "id": "template_current_ratio_simple",
    "name": "Simple Current Ratio",
    "short_description": "Calculates the current ratio using current assets and current liabilities.",
    "domain": "Financial Ratios",
    "topic": "Liquidity Ratios",
    "inputs": [
      {
        "name": "ca",
        "type": "float",
        "description": "Current assets of the company."
      },
      {
        "name": "cl",
        "type": "float",
        "description": "Current liabilities of the company."
      }
    ],
    "output_var": "current_ratio",
    "sympy_formulas": [
      {
        "variable": "current_ratio",
        "formula": "ca / cl"
      }
    ],
    "tags": [
      "liqratio",
      "current ratio",
      "liquidity"
    ]
  },
  {
    "id": "template_quick_ratio_simple",
    "name": "Quick Ratio (acid-test)",
    "short_description": "Quick Ratio (acid-test) = (Current Assets \n Inventories) \n Current Liabilities.",
    "domain": "Financial Ratios",
    "topic": "Liquidity Ratios",
    "inputs": [
      {
        "name": "ca",
        "type": "float",
        "description": "Current Assets"
      },
      {
        "name": "inv",
        "type": "float",
        "description": "Inventories"
      },
      {
        "name": "cl",
        "type": "float",
        "description": "Current Liabilities"
      }
    ],
    "output_var": "quick_ratio",
    "sympy_formulas": [
      {
        "variable": "quick_ratio",
        "formula": "(ca - inv) / cl"
      }
    ],
    "tags": [
      "liqratio",
      "quick ratio",
      "liquidity"
    ]
  },
  {
    "id": "template_both_ratios_intermediate",
    "name": "Current and Quick Ratios (Prepaid Excluded)",
    "short_description": "Compute Current and Quick Ratios, specifically excluding prepaid expenses from quick assets calculation.",
    "domain": "Financial Ratios",
    "topic": "Liquidity Ratios",
    "inputs": [
      {
        "name": "ca",
        "type": "float",
        "description": "Total current assets of the company."
      },
      {
        "name": "inv",
        "type": "float",
        "description": "Inventories held by the company."
      },
      {
        "name": "pre",
        "type": "float",
        "description": "Prepaid expenses of the company."
      },
      {
        "name": "cl",
        "type": "float",
        "description": "Total current liabilities of the company."
      }
    ],
    "output_var": "current_ratio",
    "sympy_formulas": [
      {
        "variable": "current_ratio",
        "formula": "ca / cl"
      },
      {
        "variable": "quick_ratio",
        "formula": "(ca - inv - pre) / cl"
      }
    ],
    "tags": [
      "liqratio",
      "current ratio",
      "quick ratio",
      "liquidity",
      "financial ratios"
    ]
  },
  {
    "id": "template_quick_ratio_reach_target_intermediate",
    "name": "Quick Ratio: Additional Quick Assets to Reach Target",
    "short_description": "Given a minimum quick ratio requirement, compute additional quick assets needed.",
    "domain": "Financial Ratios",
    "topic": "Liqratio",
    "inputs": [
      {
        "name": "ca",
        "type": "float",
        "description": "current assets"
      },
      {
        "name": "inv",
        "type": "float",
        "description": "inventories"
      },
      {
        "name": "pre",
        "type": "float",
        "description": "prepaid expenses"
      },
      {
        "name": "cl",
        "type": "float",
        "description": "current liabilities"
      },
      {
        "name": "target",
        "type": "float",
        "description": "minimum quick ratio requirement"
      }
    ],
    "output_var": "additional_needed",
    "sympy_formulas": [
      {
        "variable": "quick_assets_now",
        "formula": "ca - inv - pre"
      },
      {
        "variable": "required_quick_assets",
        "formula": "target * cl"
      },
      {
        "variable": "gap",
        "formula": "required_quick_assets - quick_assets_now"
      },
      {
        "variable": "additional_needed",
        "formula": "Max(0, gap)"
      }
    ],
    "tags": [
      "liqratio",
      "quick ratio",
      "liquidity",
      "target"
    ]
  },
  {
    "id": "template_liquidity_minimum_quick_ratio_advanced",
    "name": "Minimum Quick Ratio: Advanced Balance Sheet Analysis",
    "short_description": "Full balance sheet breakdown to compute Current Ratio, Quick Ratio, and the additional quick assets needed to meet a specified minimum quick ratio threshold.",
    "domain": "Financial Ratios",
    "topic": "Liquidity Ratios",
    "inputs": [
      {
        "name": "cash",
        "type": "float",
        "description": "Amount of cash on the balance sheet."
      },
      {
        "name": "mkt",
        "type": "float",
        "description": "Value of marketable securities."
      },
      {
        "name": "ar",
        "type": "float",
        "description": "Value of accounts receivable."
      },
      {
        "name": "inv",
        "type": "float",
        "description": "Value of inventory."
      },
      {
        "name": "pre",
        "type": "float",
        "description": "Value of prepaid expenses."
      },
      {
        "name": "cl",
        "type": "float",
        "description": "Total current liabilities."
      },
      {
        "name": "target",
        "type": "float",
        "description": "Minimum Quick Ratio desired as a decimal (e.g., 1.5 for 1.5:1)."
      }
    ],
    "output_var": "additional_needed",
    "sympy_formulas": [
      {
        "variable": "current_assets",
        "formula": "cash + mkt + ar + inv + pre"
      },
      {
        "variable": "quick_assets",
        "formula": "cash + mkt + ar"
      },
      {
        "variable": "current_ratio",
        "formula": "current_assets / cl"
      },
      {
        "variable": "quick_ratio",
        "formula": "quick_assets / cl"
      },
      {
        "variable": "required_quick_assets",
        "formula": "target * cl"
      },
      {
        "variable": "additional_needed",
        "formula": "Max(0, required_quick_assets - quick_assets)"
      }
    ],
    "tags": [
      "liqratio",
      "liquidity",
      "current_ratio",
      "quick_ratio",
      "balance_sheet",
      "financial_ratios"
    ]
  },
