ot_clarified": "The loan term is assumed to be in years.", "impact_scope": "input_binding"}], "inputs": [{"name": "principal", "type": "number", "required": true, "description": "The initial loan amount.", "unit": null, "aliases": []}, {"name": "annual_interest_rate", "type": "number", "required": true, "description": "The annual interest rate as a percentage (e.g., 4.5 for 4.5%).", "unit": "%", "aliases": []}, {"name": "years", "type": "integer", "required": true, "description": "The term of the loan in years.", "unit": null, "aliases": []}], "output": {"name": "total_principal_paid_first_year", "type": "number", "unit": "currency", "description": "The total amount of principal paid in the first 12 months of the mortgage."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    principal = inputs['principal']\n    annual_interest_rate = inputs['annual_interest_rate']\n    years = inputs['years']\n    monthly_interest_rate = annual_interest_rate / 100 / 12\n    num_payments = years * 12\n    if monthly_interest_rate == 0:\n        if num_payments <= 0:\n            return 0.0\n        monthly_payment = principal / num_payments\n    else:\n        monthly_payment = principal * monthly_interest_rate / (1 - (1 + monthly_interest_rate) ** (-num_payments))\n    remaining_balance = principal\n    total_principal_first_year = 0\n    for month in range(1, min(13, num_payments + 1)):\n        if remaining_balance <= 0:\n            break\n        interest_payment = remaining_balance * monthly_interest_rate\n        principal_payment = monthly_payment - interest_payment\n        principal_payment = min(principal_payment, remaining_balance)\n        remaining_balance -= principal_payment\n        total_principal_first_year += principal_payment\n    return round(total_principal_first_year)", "deterministic": true}, "diagnostic_checks": [{"rule_id": "principal_positive", "name": "Principal Positive Check", "check_type": "deterministic", 