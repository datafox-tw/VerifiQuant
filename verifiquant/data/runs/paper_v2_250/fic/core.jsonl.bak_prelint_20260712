is_default": true}, {"label": "Nominal (Undiscounted) Total", "value": "nominal_undiscounted_total", "is_default": false}], "i_level": "soft", "assumption_if_not_clarified": "Discounted Present Value", "impact_scope": "output_interpretation"}, {"id": "discount_rate_scale", "ambiguity_type": "unit_scale", "trigger_signal": "discount rate value appears to be a whole number percentage (e.g., 3 instead of 0.03)", "clarification_question": "Is the provided discount rate a decimal (e.g., 0.03) or a percentage (e.g., 3)?", "options": [{"label": "Decimal (e.g., 0.03) - DEFAULT", "value": "decimal", "is_default": true}, {"label": "Percentage (e.g., 3) - convert to decimal", "value": "percentage_to_decimal", "is_default": false}], "i_level": "soft", "assumption_if_not_clarified": "Decimal", "impact_scope": "input_binding"}], "inputs": [{"name": "claim_payments", "type": "array[number]", "required": true, "description": "A list of future claim payments (positive values), provided in chronological order.", "unit": null, "aliases": []}, {"name": "discount_rate", "type": "number", "required": true, "description": "The discount rate used for discounting future payments. Must be greater than -1.", "unit": null, "aliases": []}], "output": {"name": "present_value_reserve", "type": "number", "unit": "currency", "description": "The present value of the future claim payments, representing the estimated loss reserve."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    claim_payments = inputs['claim_payments']\n    discount_rate = inputs['discount_rate']\n    present_value_reserve = sum((payment / (1 + discount_rate) ** (i + 1) for i, payment in enumerate(claim_payments)))\n    return round(present_value_reserve)", "deterministic": true}, "diagnostic_checks": [{"rule_id": "claim_payments_list_type_f", "name": "Claim Payments Type Check", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", 