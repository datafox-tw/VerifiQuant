lue": "total_cost", "is_default": true}, {"label": "Pure cash purchase price only", "value": "cash_price", "is_default": false}], "i_level": "soft", "assumption_if_not_clarified": "Total cost including liabilities and purchase expenses, as defined in accounting principles.", "impact_scope": "input_binding"}, {"id": "sale_price_interpretation", "ambiguity_type": "input_binding", "trigger_signal": "sale price interpretation (gross vs. net of selling expenses)", "clarification_question": "Does the 'sale_price' represent the gross selling price or the net amount received after deducting selling expenses (e.g., commissions, closing costs)?", "options": [{"label": "Net amount received after selling expenses — DEFAULT", "value": "net_sale_price", "is_default": true}, {"label": "Gross selling price before any deductions", "value": "gross_sale_price", "is_default": false}], "i_level": "soft", "assumption_if_not_clarified": "Net amount received after selling expenses, consistent with performance evaluation.", "impact_scope": "input_binding"}], "inputs": [{"name": "sale_price", "type": "number", "required": true, "description": "The final sale price of the asset.", "unit": null, "aliases": []}, {"name": "unadjusted_basis", "type": "number", "required": true, "description": "The unadjusted basis or original purchase price of the asset, including initial price, liabilities, and expenses.", "unit": null, "aliases": []}], "output": {"name": "roi", "type": "number", "unit": "percent", "description": "The return on investment (ROI) as a percentage."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    sale_price = inputs['sale_price']\n    unadjusted_basis = inputs['unadjusted_basis']\n    if unadjusted_basis == 0:\n        raise ValueError('Unadjusted basis must not be zero.')\n    roi = (sale_price - unadjusted_basis) / unadjusted_basis * 100\n    return round(roi, 2)", "deterministic": true}, "diagnostic_checks": [{"rule_id": "ub_type_check", "name": "Unadjusted basis must be a number", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['unadjusted_basis'], (int, float))", "applies_to": [], "description": "The 'unadjusted_basis' input must be a numerical value."}, {"rule_id": "sp_type_check", "name": "Sale price must be a number", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['sale_price'], (int, float))", "applies_to": [], "description": "The 'sale_price' input must be a numerical value."}, {"rule_id": "ub_non_zero", "name": "Unadjusted Basis must not be zero", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['unadjusted_basis'] == 0", "applies_to": [], "description": "The unadjusted basis of the asset cannot be zero, as it is used as a divisor in the ROI calculation."}, {"rule_id": "inputs_non_negative", "name": "Sale price and unadjusted basis should be non-negative", "check_type": "deterministic", "diagnostic_type": "E", "severity": "alert", "predicate_mode": "violation", "expression": "inputs['sale_price'] < 0 or inputs['unadjusted_basis'] < 0", "applies_to": [], "description": "It is highly unusual for sale price or unadjusted basis to be negative. Please confirm if this is intended."}, {"rule_id": "roi_plausibility_high", "name": "Calculated ROI is unusually high", "check_type": "deterministic", "diagnostic_type": "E", "severity": "alert", "predicate_mode": "violation", "expression": "inputs['unadjusted_basis'] != 0 and compute(inputs) > 1000", "applies_to": [], "description": "The calculated Return on Investment exceeds 1000%, which is unusually high. Please verify inputs for accuracy."}, {"rule_id": "roi_plausibility_low", "name": "Calculated ROI is unusually low or negative", "check_type": "deterministic", "diagnostic_type": "E", "severity": "alert", "predicate_mode": "violation", "expression": "inputs['unadjusted_basis'] != 0 and compute(inputs) < -50", "applies_to": [], "description": "The calculated Return on Investment is below -50%, indicating a significant loss. Please verify inputs for accuracy."}], "execution_smoke_test": {"ok": true, "error": null, "autofix_applied": false, "lint_fixes": [], "effective_code": "def compute(inputs):\n    sale_price = inputs['sale_price']\n    unadjusted_basis = inputs['unadjusted_basis']\n    if unadjusted_basis == 0:\n        raise ValueError('Unadjusted basis must not be zero.')\n    roi = (sale_price - unadjusted_basis) / unadjusted_basis * 100\n    return round(roi, 2)"}, "article_title": "Unadjusted Basis", "article_doc_id": 3765, "article_content_excerpt": "# Unadjusted Bias: What it Means, How it Works, Example\n\n## What Is Unadjusted Basis? \n\nUnadjusted basis refers to the original cost to purchase an asset. This amount includes not only the initial price the purchaser paid to acquire the asset but also includes other costs such as expenses and liabilities assumed to purchase it. is a related term, and refers to any adjustments made to the original purchase price of an asset over time. Unadjusted basis is used mostly in accounting nomenclature and is akin to the concept of . \n\n## Understanding Unadjusted Basis \n\nUnadjusted basis is the initial value assigned to an asset. It includes the cash cost or price of an asset, any liability assumed to acquire the asset, any asset the purchaser gave to the seller as part of the transaction, and any purchase expenses incurred to acquire the asset. Purchase expenses may include commissions, fees, survey costs, , or , for example. \n\n## Example of Unadjusted Basis \n\nSam purchased a building from Emily using $100,000 in cash and a $50,000 mortgage. As part of the purchase agreement, Sam also paid $1,000 in attributed to a period of time in which Emily was still the owner of the property. Total closing costs and fees for Sam to purchase this property were $4,000. Sam's unadjusted basis for this property is $100,000 + $50,000 + $1,000 + $4,000 = $155,000. \n\n## Unadjusted Basis in Practice \n\nThe unadjusted basis is used to calculate the gain on the sale of an asset. Extending Sam's purchase example above, assume Sam later sold this piece of property for $175,000, after costs and fees associated with the sale. He could determine his by calculating the profit on the investment. He earned $20,000 ($175,000 - $155,000) net of expenses on this investment, which equates to a 12.9% return on investment (($175,000 - $155,000)/$155,000). \n\nUnadjusted basis is also the starting point for determining on an asset, such as a plant or piece of manufacturing equipment, in . Depreciation is an accounting method of allocating the cost of a tangible asset over its useful life and is used to account for declines in the value of the asset over time. Accelerated depreciation methods allow the deduction of higher expenses from the unadjusted basis in the first years after purchase and lower expenses as the depreciated item ages."}
{"fic_id": "fic_article_72", "name": "Capitalize", "short_description": "Calculates the first year's annual depreciation expense for a fixed asset using the double-declining balance method.", "domain": "accounting_and_financial_reporting", "topic": "depreciation_and_amortization", "topic_extension": false, "version": "v2", "source_meta": {"function_id": "article-72", "source": "FinanceReasoning-test-787", "question_id": "test-1499", "difficulty": 2.8903717578961645, "level": "medium", "execution_smoke_ok": true, "execution_autofix_applied": false, "normalization_version": "ast_v1_docstring_strip", "code_sanity_ok": true, "ast_exact_hash": "f7a4faf1876839258eec2cad79da41745eaa3104dd5328af5b21d7186e854203", "is_duplicate_kernel": false, "duplicate_of": null}, "selection_hints": ["depreciation calculation", "double declining balance method", "asset useful life", "first year depreciation", "capitalized cost", "accounting expense"], "semantic_hints": [{"id": "depreciation_method_clarification", "ambiguity_type": "input_interpretation", "trigger_signal": "Depreciation method not explicitly stated, or conflicting with FIC's primary implementation.", "clarification_question": "The current calculation assumes the 'double-declining balance' method as it's the primary implementation. Do you intend to use a different method?", "options": [{"label": "Yes, use Double-Declining Balance (default)", "value": "double_declining_balance", "is_default": true}, {"label": "No, I need Straight-Line depreciation (not supported by this FIC)", "value": "straight_line", "is_default": false}], "i_level": "hard", "assumption_if_not_clarified": "The 'double_declining_balance' method will be used.", "impact_scope": "input_binding"}, {"id": "depreciation_year_scope", "ambiguity_type": "time_basis", "trigger_signal": "Specific year for depreciation not explicitly mentioned, implying the first year is assumed.", "clarification_question": "This calculation is for the *first year* of depreciation using