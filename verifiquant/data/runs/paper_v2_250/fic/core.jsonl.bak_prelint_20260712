ice = inputs['stock_purchase_price']\n    strike_price = inputs['strike_price']\n    premium = inputs['premium']\n    quantity = inputs.get('quantity', 100)\n    effective_sale_price = strike_price\n    hedged_profit = (effective_sale_price - stock_purchase_price - premium) * quantity\n    return hedged_profit", "deterministic": true}, "diagnostic_checks": [{"rule_id": "premium_non_negative", "name": "Premium must be non-negative", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['premium'] < 0", "applies_to": [], "description": "The premium paid for an option cannot be negative."}, {"rule_id": "strike_price_positive", "name": "Strike price must be positive", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['strike_price'] <= 0", "applies_to": [], "description": "The strike price of a put option must be a positive value."}, {"rule_id": "stock_purchase_price_positive", "name": "Stock purchase price must be positive", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['stock_purchase_price'] <= 0", "applies_to": [], "description": "The stock purchase price must be a positive value."}, {"rule_id": "quantity_positive", "name": "Quantity of shares must be positive", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs.get('quantity', 100) <= 0", "applies_to": [], "description": "The quantity of shares covered by the put option must be a positive integer."}, {"rule_id": "premium_less_than_stock_price", "name": "Premium usually less than stock purchase price", "check_type": "deterministic", "diagnostic_type": "E", "severity": "alert", "predicate_mode": "violation", "expression": "inputs['premium'] >= inputs['stock_purchase_price']", "applies_to": [], "description":