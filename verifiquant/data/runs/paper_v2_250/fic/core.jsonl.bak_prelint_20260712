um(y_values)\n    sum_x_squared = sum((x ** 2 for x in x_values))\n    sum_y_squared = sum((y ** 2 for y in y_values))\n    sum_xy = sum((x * y for x, y in zip(x_values, y_values)))\n    numerator = n * sum_xy - sum_x * sum_y\n    denominator = ((n * sum_x_squared - sum_x ** 2) * (n * sum_y_squared - sum_y ** 2)) ** 0.5\n    if denominator == 0:\n        raise ValueError('The calculation resulted in a division by zero, likely due to zero variance in one of the data sets.')\n    correlation_coefficient = numerator / denominator\n    return correlation_coefficient", "deterministic": true}, "diagnostic_checks": [{"rule_id": "input_x_values_type", "name": "x_values must be a list", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs.get('x_values'), list)", "applies_to": ["x_values"], "description": "The 'x_values' input must be a list."}, {"rule_id": "input_y_values_type", "name": "y_values must be a list", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs.get('y_values'), list)", "applies_to": ["y_values"], "description": "The 'y_values' input must be a list."}, {"rule_id": "input_x_values_not_empty", "name": "x_values list cannot be empty", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "len(inputs.get('x_values', [])) == 0", "applies_to": ["x_values"], "description": "The 'x_values' list cannot be empty. At least two data points are required to calculate correlation."}, {"rule_id": "input_y_values_not_empty", "name": "y_values list cannot be empty", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "len(inputs.get('y_values', [])) == 0", "applies_to": ["y_values"], "description": "The 'y_values' list cannot be empty. At least two data points are required to calculate correlation."}, {"rule_id": "input_lengths_match", "name": "Input lists must have the same length", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "len(inputs.get('x_values', [])) != len(inputs.get('y_values', []))", "applies_to": ["x_values", "y_values"], "description": "The 'x_values' and 'y_values' lists must have the same number of elements."}, {"rule_id": "x_values_numeric", "name": "All x_values elements must be numerical", "check_type": "normalization", "diagnostic_type": "E", "severity": "error", "predicate_mode": "validity", "expression": "all(isinstance(val, (int, float)) for val in inputs.get('x_values', []))", "applies_to": ["x_values"], "description": "All elements in 'x_values' must be numerical."}, {"rule_id": "y_values_numeric", "name": "All y_values elements must be numerical", "check_type": "normalization", "diagnostic_type": "E", "severity": "error", "predicate_mode": "validity", "expression": "all(isinstance(val, (int, float)) for val in inputs.get('y_values', []))", "applies_to": ["y_values"], "description": "All elements in 'y_values' must be numerical."}, {"rule_id": "non_zero_variance", "name": "Cannot compute correlation for zero variance data", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "(len(inputs['x_values']) > 0 and all(val == inputs['x_values'][0] for val in inputs['x_values'])) or (len(inputs['y_values']) > 0 and all(val == inputs['y_values'][0] for val in inputs['y_values']))", "applies_to": ["x_values", "y_values"], "description": "Cannot calculate correlation if all values in either 'x_values' or 'y_values' are identical (zero variance), as this would lead to division by zero."}], "execution_smoke_test": {"ok": true, "error": null, "autofix_applied": false, "lint_fixes": [], "effective_code": "def compute(inputs):\n    x_values = inputs['x_values']\n    y_values = inputs['y_values']\n    if len(x_values) != len(y_values):\n        raise ValueError('The input lists must have the same number of elements.')\n    n = len(x_values)\n    if n == 0:\n        raise ValueError('Input lists cannot be empty.')\n    if all((val == x_values[0] for val in x_values)) or all((val == y_values[0] for val in y_values)):\n        raise ValueError('Cannot calculate correlation if all values in either list are identical (zero variance).')\n    sum_x = sum(x_values)\n    sum_y = sum(y_values)\n    sum_x_squared = sum((x ** 2 for x in x_values))\n    sum_y_squared = sum((y ** 2 for y in y_values))\n    sum_xy = sum((x * y for x, y in zip(x_values, y_values)))\n    numerator = n * sum_xy - sum_x * sum_y\n    denominator = ((n * sum_x_squared - sum_x ** 2) * (n * sum_y_squared - sum_y ** 2)) ** 0.5\n    if denominator == 0:\n        raise ValueError('The calculation resulted in a division by zero, likely due to zero variance in one of the data sets.')\n    correlation_coefficient = numerator / denominator\n    return correlation_coefficient"}, "article_title": "Correlation Coefficient", "article_doc_id": 262, "article_content_excerpt": "# The Correlation Coefficient: What It Is and What It Tells Investors\n\n## What Is the Correlation Coefficient? \n\nThe correlation coefficient is a statistical measure of the strength of a between two variables. Its values can range from -1 to 1. A correlation coefficient of -1 describes a perfect , or correlation, with values in one series rising as those in the other decline, and vice versa. A coefficient of 1 shows a perfect , or a direct relationship. A correlation coefficient of 0 means there is no linear relationship. \n\nCorrelation coefficients are used in science and finance to assess the degree of association between two variables, factors, or data sets. For example, as high oil prices are favorable for crude producers, one might assume that the correlation between oil prices and forward returns on oil stocks is strongly positive. Calculating the coefficient for these variables based on market data reveals a moderate and inconsistent correlation over lengthy periods.\n\n### Key Takeaways\n\n * Correlation coefficients are used to assess the strength of associations between data variables.\n * The most common, called a “Pearson correlation coefficient,” measures the strength and direction of a linear relationship between two variables.\n * Values always range from -1 for a perfectly inverse, or negative, relationship to 1 for a perfectly positive correlation. \n * Values at or close to zero indicate no linear relationship or a very weak correlation.\n * The coefficient values required to signal a meaningful association depend on the application. The statistical significance of a correlation can be calculated from the correlation coefficient and the number of data points in the sample, assuming a normal population distribution.\n\n## Understanding the Correlation Coefficient \n\nDifferent types of correlation coefficients are used to assess correlation based on the properties of the compared data. By far the most common is the , known as “Pearson’s R _,_ ” __ which measures the strength and direction of a linear relationship between two variables. \n\nThe Pearson coefficient uses a mathematical statistics formula to measure how closely the data points combining the two variables (with the values of one data series plotted on the x-axis and the corresponding values of the other series on the y-axis) approximate the . The line of best fit can be determined through regression analysis. \n\n### Important: \n\nThe Pearson coefficient, the most common correlation coefficient, cannot assess nonlinear associations between variables and or differentiate between dependent and independent variables.\n\nThe further the coefficient is from zero, whether it is positive or negative, the better the fit and the greater the correlation. The values of -1 (for a negative correlation) and 1 (for a positive one) describe perfect fits in which all data points align in a straight line, indicating that the variables are perfectly correlated. \n\nIn other words, the relationship is so predictable that the value of one variable can be determined from the matched value of the other. The closer the correlation coefficient is to zero, the weaker the correlation, until at zero no linear relationship exists at all. \n\n:max_bytes\\(150000\\):strip_icc\\(\\)/TC_3126228-how-to-calculate-the-correlation-coefficient-5aabeb313de423003610ee40.png)\n\nInvestopedia / Hugo Lin\n\nAssessments of correlation strength based on the correlation coefficient value vary by application. In physics and chemistry, a correlation coefficient should be lower than -0.9 or higher than 0.9 for the correlation to be considered meaningful, while in social sciences the threshold could be as high as -0.5 and as low as 0.5. \n\nFor correlation coefficients derived from , the determination of statistical significance depends on the , which is calculated from the data sample’s size as well as the value of the coefficient. \n\n## Formula for the Correlation Coefficient \n\nTo calculate the Pearson correlation, start by deter\n...[truncated]"}
{"fic_id": "fic_article_1541", "name": "Return on Average Equity (ROAE)", "short_description": "Calculates a company's profitability relative to its average shareholders' equity over a fiscal year, accounting for changes in equity.", "domain": "financial_ratios", "topic": "profitratio", "topic_extension": false, "version": "v2", "source_meta": {"function_id": "article-1541", "source": "FinanceReasoning-test-965", "question_id": "test-1034", "difficulty": 2.4849066497880004, "level": "medium", "execution_smoke_ok": true, "execution_autofix_applied": false, "normalization_version": "ast_v1_docstring_strip", "code_sanity_ok": true, "ast_exact_hash": "7ef4064ff48524cb475e79165f4819c1dd467e7a72974c71311d9cb7aac0e29c", "is_duplicate_kernel": false, "duplicate_of": null}, "selection_hints": ["ROAE", "Return on Average Equity", "company performance", "profitability ratio", "shareholders' equity", "average equity", "financial ratio"], "semantic_hints": [{"id": "output_scale", "ambiguity_type": "unit_scale", "trigger_signal": "question asks for percentage, FIC outputs decimal (or vice versa)", "clarification_question": "Should the answer be expressed as a decimal (e.g., 0.16) or as a percentage (e.g., 16.0%)?", "options": [{"label": "Decimal — DEFAULT", "value": "decimal", "is_default": true}, {"label": "Percentage", "value": "percent", "is_default": false, "transform_spec": {"patch_type": "result_postprocess", "result_expr": "result * 100.0", "max_expr_nodes": 6, "invariant": "result_new == result_old * 100.0", "affected_inputs": []}}], "i_level": "soft", "assumption_if_not_clarified": "Decimal", "impact_scope": "output_interpretation"}], "inputs": [{"name": "net_income", "type": "number", "required": true, "description": "The net income of the company for the fiscal year.", "unit": null, "aliases": ["net_income"]}, {"name": "beginning_equity", "type": "number", "required": true, "description": "The shareholders' equity at the beginning of the year.", "unit": null, "aliases": ["beginning_shareholders_equity", "shareholders_equity_at_start", "start_of_year_equity"]}, {"name": "ending_equity", "type": "number", "required": true, "description": "The shareholders' equity at the end of the year.", "unit": null, "aliases": ["ending_shareholders_equity", "shareholders_equity_at_end", "end_of_year_equity"]}], "output": {"name": "roae", "type": "number", "unit": "decimal", "description": "The Return on Average Equity as a decimal."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    net_income = inputs['net_income']\n    beginning_equity = inputs['beginning_equity']\n    ending_equity = inputs['ending_equity']\n    average_equity = (beginning_equity + ending_equity) / 2\n    roae = net_income / average_equity\n    return roae", "deterministic": true}, "diagnostic_checks": [{"rule_id": "roae_f_001", "name": "Required input: net_income", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs.get('net_income'), (int, float))", "applies_to": ["net_income"], "description": "Net income must be provided and be a numeric value."}, {"rule_id": "roae_f_002", "name": "Required input: beginning_equity", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs.get('beginning_equity'), (int, float))", "applies_to": ["beginning_equity"], "description": "Beginning shareholders' equity must be provided and be a numeric value."}, {"rule_id": "roae_f_003", "name": "Required input: ending_equity", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs.get('ending_equity'), (int, float))", "applies_to": ["ending_equity"], "description": "Ending shareholders' equity must be provided and be a numeric value."}, {"rule_id": "roae_e_001", "name": "Equity values must be positive", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['beginning_equity'] <= 0 or inputs['ending_equity'] <= 0", "applies_to": ["beginning_equity", "ending_equity"], "description": "Both beginning and ending shareholders' equity must be positive values to calculate a meaningful ROAE."}, {"rule_id": "roae_e_002", "name": "Average equity cannot be zero", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "(inputs['beginning_equity'] + inputs['ending_equity']) / 2 == 0", "applies_to": ["beginning_equity", "ending_equity"], "description": "The average shareholders' equity cannot be zero, as it would lead to an undefined ROAE."}, {"rule_id": "roae_e_003", "name": "Plausible ROAE range", "check_type": "deterministic", "diagnostic_type": "E", "severity": "alert", "predicate_mode": "violation", "expression": "compute(inputs) < -5.0 or compute(inputs) > 10.0", "applies_to": ["net_income", "beginning_equity", "ending_equity"], "description": "Return on Average Equity (ROAE) results typically fall within a range of -500% to 1000%. Values outside this range may indicate unusual financial performance or data entry error."}], "execution_smoke_test": {"ok": true, "error": null, "autofix_applied": false, "lint_fixes": [], "effective_code": "def compute(inputs):\n    net_income = inputs['net_income']\n    beginning_equity = inputs['beginning_equity']\n    ending_equity = inputs['ending_equity']\n    average_equity = (beginning_equity + ending_equity) / 2\n    roae = net_income / average_equity\n    return roae"}, "article_title": "Return on Average Equity (ROAE)", "article_doc_id": 3030, "article_content_excerpt": "# Return On Average Equity (ROAE): Definition and What It Indicates\n\n## What Is Return on Average Equity (ROAE)? \n\nReturn on average equity (ROAE) is a financial ratio that measures the performance of a company based on its average shareholders' equity outstanding. Typically, ROAE refers to a company's performance over a fiscal year, so the ROAE numerator is and the denominator is computed as the sum of the equity value at the beginning and end of the year, divided by 2. \n\nReturn on average equity differs from the more common Return on Equity (ROE), which measures net income for the year divided by the amount of shareholder equity at the end of the year, which can be subject to stocks sales, dividend payments, and other share dilutions. \n\n### Key Takeaways\n\n * A high ROAE means a company is creating more income for each dollar of stockholders' equity. \n * ROAE also reveals how a company is making its money, whether through profitability, debt accumulation, or asset sales, for example. \n * To discern actual profitability, is calculated by dividing net income by sales. \n * The average is a measure of asset efficiency and is calculated by dividing sales by the average total assets. \n * The , measured as the average assets divided by the average stockholders' equity, is a measure of the firm's debt level.\n\n## The Basics of Return On Average Equity (ROAE) \n\nThe (ROE), a determinant of performance, is calculated by dividing net income by the ending value in the balance sheet. This equity value can include last-minute stock sales, , and dividend payments. This means that ROE may not accurately reflect a business' actual return over a period of time. \n\nThe return on average equity (ROAE) can give a more accurate depiction of a company's corporate profitability, especially if the value of the shareholders' equity has changed considerably during a . ROAE is an adjusted version of the return on equity (ROE) measure of company profitability, in which the denominator, shareholders' equity, is changed to average shareholders' equity. Basically, instead of dividing net income by stockholders' equity, an analyst divides net income by the sum of the equity value at the beginning and end of the year, divided by 2. \n\nNet income is found on the in the annual report. Stockholders' equity is found at the bottom of the in the annual report. The income statement captures transactions from the entire year, whereas the balance sheet is a snapshot in time. As a result, analysts divide net income by an average of the beginning and end of the time period for balance sheet line items. If a business rarely experiences significant changes in its shareholders' equity, it is probably not necessary to use an average equity figure in the denominator of the calculation. \n\nIn situations where the shareholders' equity does not change or changes by very little during a fiscal year, the ROE and ROAE numbers should be identical, or at least similar. \n\n## An Example of ROAE \n\nThe key equation is: ROAE= Net Income/ Average Stockholders’ Equity \n\nFor example, Company XYZ starts out last year with $1,000,000 in shareholder equity and finishes the next year with $ 1,500,000 in shareholder equity, due to investments from investors, leaving them with an average shareholder equity value of $1,250,000 for the year. These figures can be found from the balance sheet of the last year and the end of the current year. During the current year, XYZ earns $200,000 in net income (found on the income statement for the end of the current year). Using the ROAE equation: Net income/ (Prior year shareholder equity + Current year shareholder value / 2), the result is $200,000/1,250,000= 16% gain. \n\nInvestors will want to compare ROE’s and ROAE’s between companies in similar sectors to see which are most profitable and efficient based on shareholder equity. If company XYZ is muddling along with a sub-10% ROAE and company ABC is turning in a +20% ROAE, investors will have a better understandin\n...[truncated]"}
