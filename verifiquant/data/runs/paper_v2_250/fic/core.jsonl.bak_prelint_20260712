es": []}, {"name": "interest", "type": "number", "required": true, "description": "Interest expense of the company.", "unit": null, "aliases": []}, {"name": "tax_rate", "type": "number", "required": true, "description": "Tax rate applied to the company's earnings (as a decimal, e.g., 0.25 for 25%).", "unit": null, "aliases": []}, {"name": "li", "type": "number", "required": true, "description": "Long-term investments made by the company.", "unit": null, "aliases": []}, {"name": "iwc", "type": "number", "required": true, "description": "Investments in working capital by the company.", "unit": null, "aliases": []}], "output": {"name": "fcff", "type": "number", "unit": "currency_unit", "description": "Calculated free cash flow to the firm."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    ni = inputs['ni']\n    nc = inputs['nc']\n    interest = inputs['interest']\n    tax_rate = inputs['tax_rate']\n    li = inputs['li']\n    iwc = inputs['iwc']\n    fcff = ni + nc + interest * (1 - tax_rate) - li - iwc\n    return fcff", "deterministic": true}, "diagnostic_checks": [{"rule_id": "e001_tax_rate_bounds", "name": "Tax rate must be between 0 and 1 (as decimal)", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "not (0 <= inputs['tax_rate'] <= 1)", "applies_to": [], "description": "The tax rate, expected as a decimal, must be between 0 and 1 inclusive."}, {"rule_id": "e002_non_negative_non_ni_monetary_inputs", "name": "Non-Net Income monetary inputs must be non-negative", "check_type": "deterministic", "diagnostic_type": "E", "severity": "alert", "predicate_mode": "violation", "expression": "inputs['nc'] < 0 or inputs['interest'] < 0 or inputs['li'] < 0 or inputs['iwc'] < 0", "applies_to": [], "description": "Non-cash charges, interest expense, long-term investments, and investments in working capital should generally not be negative."}, {"rule_id": "e003_