mark_returns = sum(benchmark_returns) / n\n    covariance = sum(((a - mean_asset_returns) * (b - mean_benchmark_returns) for a, b in zip(asset_returns, benchmark_returns))) / n\n    variance = sum(((b - mean_benchmark_returns) ** 2 for b in benchmark_returns)) / n\n    if variance == 0:\n        raise ValueError('Benchmark returns variance is zero, cannot calculate beta.')\n    beta = covariance / variance\n    return beta", "deterministic": true}, "diagnostic_checks": [{"rule_id": "ar001", "name": "Asset returns input validation", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs.get('asset_returns'), list)", "applies_to": ["asset_returns"], "description": "Asset returns must be provided as a list."}, {"rule_id": "br001", "name": "Benchmark returns input validation", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs.get('benchmark_returns'), list)", "applies_to": ["benchmark_returns"], "description": "Benchmark returns must be provided as a list."}, {"rule_id": "arbr002", "name": "All returns elements must be numeric", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "all(isinstance(x, (int, float)) for x in inputs.get('asset_returns', [])) and all(isinstance(x, (int, float)) for x in inputs.get('benchmark_returns', []))", "applies_to": ["asset_returns", "benchmark_returns"], "description": "All elements in both asset_returns and benchmark_returns lists must be numbers."}, {"rule_id": "arbr003", "name": "Returns lists cannot be empty", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "not inputs.get('asset_returns') or not inputs.get('benchmark_returns')", "applies_to": ["asset_returns", "benchmark_returns"], "description": "Both asset_returns and be