lue * weight for value, weight in zip(values, weights)))\n    total_weights = sum(weights)\n    weighted_average = total_weighted_values / total_weights\n    return weighted_average", "deterministic": true}, "diagnostic_checks": [{"rule_id": "input_values_type", "name": "Validate 'values' input type and elements", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['values'], list) and all(isinstance(v, (int, float)) for v in inputs['values'])", "applies_to": ["values"], "description": "'values' must be a list containing only numbers (integers or floats)."}, {"rule_id": "input_weights_type", "name": "Validate 'weights' input type and elements", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['weights'], list) and all(isinstance(w, (int, float)) for w in inputs['weights'])", "applies_to": ["weights"], "description": "'weights' must be a list containing only numbers (integers or floats)."}, {"rule_id": "input_lengths_match", "name": "Validate lengths of 'values' and 'weights' lists", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "validity", "expression": "len(inputs['values']) == len(inputs['weights'])", "applies_to": ["values", "weights"], "description": "The number of elements in 'values' must be equal to the number of elements in 'weights'."}, {"rule_id": "sum_of_weights_not_zero", "name": "Validate that the sum of 'weights' is not zero", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "validity", "expression": "sum(inputs['weights']) != 0", "applies_to": ["weights"], "description": "The sum of all weights cannot be zero to avoid division by zero."}, {"rule_id": "non_negative_weights", "name": "Validate 'weights' are non-negative", "check_type": "deterministic", "diagnostic_type": "E", "severity": 