scope": "input_binding"}], "inputs": [{"name": "beginning_ap", "type": "number", "required": true, "description": "The accounts payable value at the beginning of the period.", "unit": null, "aliases": ["beginning_accounts_payable", "start_ap"]}, {"name": "ending_ap", "type": "number", "required": true, "description": "The accounts payable value at the end of the period.", "unit": null, "aliases": ["ending_accounts_payable", "end_ap"]}, {"name": "cogs", "type": "number", "required": true, "description": "Cost of Goods Sold for the period.", "unit": null, "aliases": ["cost_of_goods_sold"]}, {"name": "period_days", "type": "integer", "required": true, "description": "The number of days in the period (e.g., 365 for a year, 90 for a quarter).", "unit": null, "aliases": ["days_in_period", "fiscal_days"]}], "output": {"name": "dpo", "type": "number", "unit": "days", "description": "The Days Payable Outstanding, indicating how many days a company takes to pay its suppliers."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    beginning_ap = inputs['beginning_ap']\n    ending_ap = inputs['ending_ap']\n    cogs = inputs['cogs']\n    period_days = inputs['period_days']\n    average_ap = 0.5 * (beginning_ap + ending_ap)\n    dpo = average_ap / (cogs / period_days)\n    return round(dpo, 2)", "deterministic": true}, "diagnostic_checks": [{"rule_id": "input_completeness_and_type", "name": "All required inputs must be present and numeric.", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "all(isinstance(inputs[k], (int, float)) for k in ['beginning_ap', 'ending_ap', 'cogs', 'period_days'])", "applies_to": ["beginning_ap", "ending_ap", "cogs", "period_days"], "description": "Ensures that all necessary financial inputs for DPO calculation are provided and are valid numbers."}, {"rule_id": "non_negative_monetary_values", "name": "Accounts payable and COGS must be non-