esult * 100.0", "max_expr_nodes": 6, "invariant": "result_new == result_old * 100.0", "affected_inputs": []}}], "i_level": "soft", "assumption_if_not_clarified": "Decimal", "impact_scope": "output_interpretation"}], "inputs": [{"name": "loan_amounts", "type": "array[number]", "required": true, "description": "A list of loan amounts corresponding to each interest rate.", "unit": null, "aliases": []}, {"name": "interest_rates", "type": "array[number]", "required": true, "description": "A list of interest rates for each loan amount (expected in decimal form, e.g., 0.05 for 5%).", "unit": null, "aliases": []}], "output": {"name": "blended_rate", "type": "number", "unit": null, "description": "The calculated blended interest rate as a decimal."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    loan_amounts = inputs['loan_amounts']\n    interest_rates = inputs['interest_rates']\n    if len(loan_amounts) != len(interest_rates):\n        raise ValueError('The loan amounts and interest rates lists must have the same length.')\n    total_amount = sum(loan_amounts)\n    weighted_sum = sum((amount * rate for amount, rate in zip(loan_amounts, interest_rates)))\n    blended_rate = weighted_sum / total_amount\n    return blended_rate", "deterministic": true}, "diagnostic_checks": [{"rule_id": "l_001", "name": "List Length Mismatch", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "len(inputs['loan_amounts']) != len(inputs['interest_rates'])", "applies_to": [], "description": "The number of loan amounts must match the number of interest rates."}, {"rule_id": "l_002", "name": "Non-Positive Loan Amount", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "any(amount <= 0 for amount in inputs['loan_amounts'])", "applies_to": [], "description": "All loan amounts must be positive."}, {"rule_id": "l_003", "name": "Negative Interest Rate", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "any(rate < 0 for rate in inputs['interest_rates'])", "applies_to": [], "description": "All interest rates must be non-negative."}, {"rule_id": "l_004", "name": "Unusually High Interest Rate", "check_type": "deterministic", "diagnostic_type": "E", "severity": "alert", "predicate_mode": "violation", "expression": "any(rate > 1 for rate in inputs['interest_rates'])", "applies_to": [], "description": "Interest rates are unusually high. Ensure they are in decimal form (e.g., 0.05 for 5%) and not percentage form (e.g., 5 for 5%)."}, {"rule_id": "l_005", "name": "Zero Total Loan Amount", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "sum(inputs['loan_amounts']) == 0", "applies_to": [], "description": "The sum of all loan amounts cannot be zero to calculate a blended rate."}, {"rule_id": "l_006", "name": "Invalid Loan Amounts Type", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "not isinstance(inputs['loan_amounts'], list) or not all(isinstance(x, (int, float)) for x in inputs['loan_amounts'])", "applies_to": [], "description": "Loan amounts must be a list of numbers (integers or floats)."}, {"rule_id": "l_007", "name": "Invalid Interest Rates Type", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "not isinstance(inputs['interest_rates'], list) or not all(isinstance(x, (int, float)) for x in inputs['interest_rates'])", "applies_to": [], "description": "Interest rates must be a list of numbers (integers or floats)."}], "execution_smoke_test": {"ok": true, "error": null, "autofix_applied": false, "lint_fixes": [], "effective_code": "def compute(inputs):\n    loan_amounts = inputs['loan_amounts']\n    interest_rates = inputs['interest_rates']\n    if len(loan_amounts) != len(interest_rates):\n        raise ValueError('The loan amounts and interest rates lists must have the same length.')\n    total_amount = sum(loan_amounts)\n    weighted_sum = sum((amount * rate for amount, rate in zip(loan_amounts, interest_rates)))\n    blended_rate = weighted_sum / total_amount\n    return blended_rate"}, "article_title": "Blended Rate", "article_doc_id": 1369, "article_content_excerpt": "# Blended Rate: Definition, Examples, and Calculation Formula\n\n## What Is a Blended Rate? \n\nA blended rate is an interest rate charged on a loan that represents the combination of a previous rate and a new rate. Blended rates are usually offered through the refinancing of existing loans that are charged a rate of interest that is higher than the old loan's rate, but lower than the rate on a brand-new loan. \n\nThis type of rate is calculated for accounting purposes to better understand the true debt obligation for multiple loans with different rates or the revenue from several streams of interest. \n\n### Key Takeaways\n\n * A blended rate is an interest rate charged on a loan that represents the combination of a previous rate and a new rate.\n * Blended rates can apply to refinanced corporate debt, or to consumer loans, such as a refinanced mortgage.\n * To calculate the blended rate, most often you will take the weighted average of the interest rates on the loans.\n\n### Important: \n\nBlended rates are often used to understand the true interest rate paid when refinancing a loan, but they can also be used when adding additional debt, such as a second mortgage.\n\n## How Blended Rates Work \n\nA blended rate is used by lenders to encourage borrowers to refinance existing low-interest loans and also used to calculate the . These rates also represent a weighted average interest rate on corporate debt. The resulting rate is considered the aggregate interest rate on corporate debt. \n\nBlended rates also apply to individual borrowers who refinance a personal loan or mortgage. There are several free online calculators available for consumers to compute their blended average interest rate after a refinance. \n\n## Examples of Blended Rates \n\nBlended rates can apply to refinanced corporate debt, or to personal loans taken out by individuals. Calculating the blended rate involves taking the weighted average of the interest rates on the loans. \n\n### Corporate Debt \n\nSome companies have more than one type of . For example, if a company has $50,000 in debt at a 5% interest rate and $50,000 in debt at a 10% interest rate, the total blended rate would be calculated as: \n\n> (50,000 x 0.05 + 50,000 x 0.10) / (50,000 + 50,000) = 7.5% \n\nThe blended rate is also used in cost-of-funds accounting to quantify liabilities or investment income on a balance sheet. For example, if a company had two loans, one for $1,000 at 5% and the other for $3,000 at 6%, and it paid the interest off every month, the $1,000 loan would charge $50 after one year, and the $3,000 loan would charge $180. The blended rate would thus be: \n\n> (50 + 180) / 4,000 = 5.75% \n\nAs another hypothetical example, suppose Company A announced 2Q 2020 results with a note in the earnings report on the balance sheet section that outlined the company's blended rate on its $3.5 billion debt. Its blended interest rate for the quarter was 3.76%. \n\n### Personal Loans \n\nBanks use a blended rate to retain customers and increase loan amounts to proven, creditworthy clients. For example, if a customer currently holds a $75,000 mortgage with a 7% interest rate and wishes to refinance when the current rate is 9%, the bank might offer a blended rate of 8%. The borrower could then decide to refinance for $150,000 with a blended rate of 8%."}
{"fic_id": "fic_article_2845", "name": "Exponential Moving Average (EMA)", "short_description": "Calculates the Exponential Moving Average (EMA) of a list of prices, emphasizing recent data points.", "domain": "financial_markets", "topic": "stock_market_analysis", "topic_extension": false, "version": "v2", "source_meta": {"function_id": "article-2845", "source": "FinanceReasoning-test-110", "question_id": "test-2148", "difficulty": 4.941642422609304, "level": "hard", "execution_smoke_ok": true, "execution_autofix_applied": false, "normalization_version": "ast_v1_docstring_strip", "code_sanity_ok": true, "ast_exact_hash": "73079bfc681b38b642ffc9d99ab72b1916245d478b446aeed53f16897496f4af", "is_duplicate_kernel": false, "duplicate_of": null}, "selection_hints": ["EMA", "Exponential Moving Average", "technical analysis", "stock prices", "smoothing", "moving average"], "semantic_hints": [{"id": "price_source", "ambiguity_type": "input_binding", "trigger_signal": "price data source (e.g., closing, open, high, low, median) not explicitly specified", "clarification_question": "Which type of price should be used for EMA calculation?", "options": [{"label": "Closing Price (DEFAULT)", "value": "closing_price", "is_default": true}, {"label": "Open Price", "value": "open_price", "is_default": false}, {"label": "High Price", "value": "high_price", "is_default": false}, {"label": "Low Price", "value": "low_price", "is_default": false}, {"label": "Median Price", "value": "median_price", "is_default": false}], "i_level": "soft", "assumption_if_not_clarified": "Closing price is used for EMA calculation.", "impact_scope": "input_binding"}, {"id": "output_rounding", "ambiguity_type": "numerical_precision", "trigger_signal": "rounding precision for the EMA result not explicitly stated", "clarification_question": "Should the EMA value be rounded to a specific number of decimal places?", "options": [{"label": "No rounding (full precision) - DEFAULT", "value": "full_precision", "is_default