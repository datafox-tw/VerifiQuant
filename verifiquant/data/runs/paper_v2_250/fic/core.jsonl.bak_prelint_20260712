y_type": "output_interpretation", "trigger_signal": "context mentions adjustable-rate mortgages (ARMs) which often have rate caps, but function does not account for them", "clarification_question": "This calculation does NOT account for potential rate caps. Should the payment reflect potential rate caps, or is this a calculation ignoring caps for illustrative purposes?", "options": [{"label": "Payment calculated without considering rate caps - DEFAULT", "value": "no_caps_considered", "is_default": true}, {"label": "Acknowledge that actual payment might be capped (requires re-calculation/external input)", "value": "caps_should_be_considered", "is_default": false}], "i_level": "soft", "assumption_if_not_clarified": "The calculation should proceed without accounting for rate caps, as per the function's limitations.", "impact_scope": "output_interpretation"}], "inputs": [{"name": "principal", "type": "number", "required": true, "description": "The remaining loan amount (principal) in dollars.", "unit": "dollars", "aliases": []}, {"name": "years", "type": "integer", "required": true, "description": "The remaining number of years on the loan.", "unit": "years", "aliases": []}, {"name": "index_rate", "type": "number", "required": true, "description": "The current index rate as a percentage (e.g., 2 for 2%).", "unit": "percent", "aliases": []}, {"name": "margin", "type": "number", "required": true, "description": "The bank's margin as a percentage (e.g., 1.5 for 1.5%).", "unit": "percent", "aliases": []}], "output": {"name": "adjusted_monthly_payment", "type": "number", "unit": "dollars", "description": "The adjusted monthly mortgage payment in dollars, rounded to the nearest cent."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    principal = inputs['principal']\n    years = inputs['years']\n    index_rate = inputs['index_rate']\n    margin = inputs['margin']\n    adjusted_annual_rate = index_rate + margin\n    if adjusted_annual_rate == 0:\n        number_of_payments = years * 12\n        if number_of_payments == 0:\n            return 0.0\n        return round(principal / number_of_payments, 2)\n    monthly_interest_rate = adjusted_annual_rate / 100 / 12\n    number_of_payments = years * 12\n    adjusted_monthly_payment = principal * monthly_interest_rate / (1 - (1 + monthly_interest_rate) ** (-number_of_payments))\n    return round(adjusted_monthly_payment, 2)", "deterministic": true}, "diagnostic_checks": [{"rule_id": "principal_required_type", "name": "Principal is required and numeric", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs.get('principal'), (int, float))", "applies_to": ["principal"], "description": "The 'principal' input is required and must be a numeric value."}, {"rule_id": "principal_positive", "name": "Principal must be positive", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['principal'] <= 0", "applies_to": ["principal"], "description": "The remaining principal amount must be a positive value."}, {"rule_id": "years_required_type_positive_integer", "name": "Years is required, positive integer", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs.get('years'), int) and inputs['years'] > 0", "applies_to": ["years"], "description": "The 'years' input is required and must be a positive integer representing the remaining loan duration."}, {"rule_id": "index_rate_required_type", "name": "Index Rate is required and numeric", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs.get('index_rate'), (int, float))", "applies_to": ["index_rate"], "description": "The 'index_rate' input is required and must be a numeric value."}, {"rule_id": "index_rate_non_negative", "name": "Index Rate must be non-negative", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['index_rate'] < 0", "applies_to": ["index_rate"], "description": "The 'index_rate' must be zero or a positive percentage."}, {"rule_id": "margin_required_type", "name": "Margin is required and numeric", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs.get('margin'), (int, float))", "applies_to": ["margin"], "description": "The 'margin' input is required and must be a numeric value."}, {"rule_id": "margin_non_negative", "name": "Margin must be non-negative", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['margin'] < 0", "applies_to": ["margin"], "description": "The 'margin' must be zero or a positive percentage."}, {"rule_id": "total_rate_plausibility", "name": "Total annual rate should be plausible", "check_type": "deterministic", "diagnostic_type": "E", "severity": "alert", "predicate_mode": "violation", "expression": "(inputs['index_rate'] + inputs['margin']) > 30.0", "applies_to": ["index_rate", "margin"], "description": "The sum of the index rate and margin results in an unusually high annual interest rate (exceeds 30%). This may indicate an input error (e.g., decimal vs percentage)."}], "execution_smoke_test": {"ok": true, "error": null, "autofix_applied": false, "lint_fixes": [], "effective_code": "def compute(inputs):\n    principal = inputs['principal']\n    years = inputs['years']\n    index_rate = inputs['index_rate']\n    margin = inputs['margin']\n    adjusted_annual_rate = index_rate + margin\n    if adjusted_annual_rate == 0:\n        number_of_payments = years * 12\n        if number_of_payments == 0:\n            return 0.0\n        return round(principal / number_of_payments, 2)\n    monthly_interest_rate = adjusted_annual_rate / 100 / 12\n    number_of_payments = years * 12\n    adjusted_monthly_payment = principal * monthly_interest_rate / (1 - (1 + monthly_interest_rate) ** (-number_of_payments))\n    return round(adjusted_monthly_payment, 2)"}, "article_title": "3/27 Adjustable-Rate Mortgage (ARM)", "article_doc_id": 1848, "article_content_excerpt": "# 3/27 Adjustable-Rate Mortgage (ARM)\n\nA 3/27 adjustable-rate mortgage (ARM) is a 30-year loan that carries a fixed interest rate for the first three years, then a variable rate for the remaining 27 years. Borrowers often use a 3/27 ARM as a short-term financing vehicle that they can later refinance into a mortgage with more favorable terms. \n\n### Key Takeaways\n\n * A 3/27 adjustable-rate mortgage (ARM) is a 30-year mortgage with a three-year fixed interest rate period.\n * The fixed interest rate is generally lower than the current rates on 30-year conventional mortgages.\n * After three years, and for the remaining 27 years of the loan, the interest rate will float based on an index, such as the yield on one-year U.S. Treasury bills.\n * Because their monthly payments can rise significantly once the interest rate adjusts, borrowers should plan carefully before taking out a 3/27 ARM to make sure it will still be affordable.\n\n## How a 3/27 ARM Works \n\n are a type of home loan in which the interest rate applied to the outstanding balance varies throughout the life of the loan. With an ARM, the initial interest rate is fixed for a period of time. After that, the rate resets periodically, at yearly, semiannual, or even monthly intervals. \n\nARMs differ from , the other primary mortgage type, which charge a set rate of interest that remains the same for the entirety of the loan. \n\n3/27 ARMs are a kind of hybrid. For the first three years, they have a fixed interest rate, which is generally lower than the current rates on 30-year conventional mortgages. But after that, and for the remaining 27 years of the loan, their interest rate will fluctuate based on a benchmark index, such as the yield on one-year U.S. . \n\nThe lender also adds a on top of the index to set the interest rate that the borrower will actually pay. The total is known as the . This rate is often substantially higher than the initial three-year fixed interest rate, although 3/27 ARMs usually have caps on how quickly they can increase. \n\nTypically, the interest rate on a 3/27 ARM won’t increase more than 2% per adjustment period, which can occur every six or 12 months. That means the rate can increase by two full percentage points (not 2% of the current interest rate). So, for example, the rate might go from 4% to 6% in a single adjustment period. \n\nThere might also be a life-of-the-loan cap set at 5% or more. In that case, the interest rate on a mortgage that started at 4% might go no higher than 9%, regardless of what happens with the index on which it is based. \n\n## 3/27 ARM Example \n\nSay a borrower takes out a $250,000 3/27 ARM at an initial fixed rate of 3.5%. For the first three years, their monthly mortgage payment will be $1,123. \n\nThen let’s assume that after three years, the benchmark interest rate is 3% and the bank’s margin is 2.5%. That adds up to a fully indexed rate of 5.5%. \n\nIf the borrower still has the 3/27 ARM and hasn’t refinanced into a different mortgage, their monthly payment will now be $1,483, an increase of $360. \n\n### Important: \n\nTo avoid payment shock when the interest rate begins to adjust, borrowers with 3/27 ARMs should aim to refinance the mortgage within the first three years.\n\n## Risks of a 3/27 ARM \n\nThe most serious risks for borrowers with a 3/27 mortgage are that they won’t be able to refinance their loan before the adjustable rate kicks in and that interest rates will have shot up in the meantime. That could happen if their credit score is too low, if their home has fallen in value, or simply if market forces have caused interest rates to rise across the board. \n\nIn that event, they would be stuck with the adjustable rate, which could mean considerably higher monthly payments, as in the example above. \n\n## ARM Prepayment Penalties \n\nBorrowers should also be aware that ARMs, including 3/27 mortgages, may carry , which can make refinancing costly and defeat the purpose of taking out an ARM with the intention of switching to a differen\n...[truncated]"}
{"fic_id": "fic_article_1130", "name": "Geometric Mean", "short_description": "Calculates the geometric mean of a series of investment returns, providing an average rate of return that accounts for compounding.", "domain": "investment_analysis", "topic": "returns_analysis", "topic_extension": true, "version": "v2", "source_meta": {"function_id": "article-1130", "source": "FinanceReasoning-test-511", "question_id": "test-1909", "difficulty": 3.8066624897703196, "level": "medium", "execution_smoke_ok": true, "execution_autofix_applied": false, "normalization_version": "ast_v1_docstring_strip", "code_sanity_ok": true, "ast_exact_hash": "a8afcebf2bab4302e571f279884e73018ff05091df240e256af4a3d686f84c00", "is_duplicate_kernel": false, "duplicate_of": null}, "selection_hints": ["geometric mean", "average compounded return", "portfolio performance", "investment analysis", "annualized return"], "semantic_hints": [{"id": "output_scale", "ambiguity_type": "unit_scale", "trigger_signal": "question asks for percentage, FIC outputs decimal (or vice versa)", "clarification_question": "Should the geometric mean be expressed as a decimal (e.g., 0.0399) or a percentage (e.g., 3.99%)?", "options": [{"label": "Decimal - DEFAULT", "value": "decimal", "is_default": true}, {"label": "Percentage", "value": "percentage", "is_default": false, "transform_spec": {"patch_type": "result_postprocess", "result_expr": "result * 100.0", "max_expr_nodes": 6, "invariant": "result_new == result_old * 100.0", "affected_inputs": []}}], "i_level": "soft", "assumption_if_not_clarified": "Decimal", "impact_scope": "output_interpretation"}], "inputs": [{"name": "returns", "type": "array[number]", "required": true, "description": "A list of investment returns for each period (expressed as decimals, e.g., 0.05 for 5%).", "unit": null, "aliases": []}], "output": {"name": "geometric_mean", "type": "number", "unit": "decimal", "description": "The geometric mean of the returns (expressed as a decimal)."}, "executi