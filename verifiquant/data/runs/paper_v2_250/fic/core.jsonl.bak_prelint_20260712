 {"label": "Custom linear weights (e.g., starting with a specific value and decrementing linearly)", "value": "custom_linear_weights", "is_default": false}], "i_level": "soft", "assumption_if_not_clarified": "Weights are assigned as lookback_period, lookback_period-1, ..., 1.", "impact_scope": "output_interpretation"}], "inputs": [{"name": "prices", "type": "array[number]", "required": true, "description": "A list of prices for the periods, ordered from the most recent to the oldest price.", "unit": null, "aliases": []}, {"name": "lookback_period", "type": "integer", "required": true, "description": "The number of periods to include in the LWMA calculation.", "unit": null, "aliases": []}], "output": {"name": "lwma", "type": "number", "unit": null, "description": "The calculated linearly weighted moving average."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    prices = inputs['prices']\n    lookback_period = inputs['lookback_period']\n    if lookback_period <= 0:\n        raise ValueError('Lookback period must be a positive integer.')\n    if len(prices) < lookback_period:\n        raise ValueError('The length of prices list must be equal to or greater than the lookback period.')\n    weights = list(range(lookback_period, 0, -1))\n    relevant_prices = prices[:lookback_period]\n    weighted_sum = sum((price * weight for price, weight in zip(relevant_prices, weights)))\n    sum_of_weights = sum(weights)\n    lwma = weighted_sum / sum_of_weights\n    return lwma", "deterministic": true}, "diagnostic_checks": [{"rule_id": "prices_is_list", "name": "Prices input must be a list", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['prices'], list)", "applies_to": [], "description": "The 'prices' input must be a list of numerical values."}, {"rule_id": "lookback_period_is_int", "name": "Lookback period must be an integer", "check_type": "