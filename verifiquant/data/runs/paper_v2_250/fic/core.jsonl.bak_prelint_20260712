ation"}], "inputs": [{"name": "numbers", "type": "array[number]", "required": true, "description": "A list of numerical values for which to calculate the median.", "unit": null, "aliases": ["data_set", "values", "observations", "annual_returns"]}], "output": {"name": "median", "type": "number", "unit": "percent", "description": "The median value of the list of numbers, expressed as a percentage."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    numbers = inputs['numbers']\n    if not numbers:\n        raise ValueError('The list of numbers must contain at least one element.')\n    sorted_numbers = sorted(numbers)\n    n = len(sorted_numbers)\n    midpoint = n // 2\n    if n % 2 == 1:\n        median = float(sorted_numbers[midpoint])\n    else:\n        median = (sorted_numbers[midpoint - 1] + sorted_numbers[midpoint]) / 2.0\n    return round(median, 2)", "deterministic": true}, "diagnostic_checks": [{"rule_id": "input_type_check", "name": "Numbers input must be a list", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['numbers'], list)", "applies_to": ["numbers"], "description": "The 'numbers' input must be a list of numerical values."}, {"rule_id": "empty_list_check", "name": "Numbers list cannot be empty", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "len(inputs['numbers']) == 0", "applies_to": ["numbers"], "description": "The list of numbers provided for median calculation must not be empty."}, {"rule_id": "list_elements_type_check", "name": "All elements in numbers must be numerical", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "all(isinstance(x, (int, float)) for x in inputs['numbers'])", "applies_to": ["numbers"], "description": "Each element in the 'numbers' list must be an 