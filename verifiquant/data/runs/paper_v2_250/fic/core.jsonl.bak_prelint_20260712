ber]", "required": true, "description": "A list of tuples, each representing a purchase, containing two elements: (units_purchased: int, cost_per_unit: float). These should be ordered by the oldest purchase first.", "unit": null, "aliases": ["inventory_purchases", "stock_acquisition_costs"]}], "output": {"name": "fifo_cogs", "type": "number", "unit": "USD", "description": "The total cost of goods sold using the FIFO method, rounded to the nearest cent."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    units_sold = inputs['units_sold']\n    purchase_costs = inputs['purchase_costs']\n    total_cost = 0.0\n    units_remaining = units_sold\n    for units_purchased, cost_per_unit in purchase_costs:\n        if units_remaining <= 0:\n            break\n        if units_remaining >= units_purchased:\n            total_cost += units_purchased * cost_per_unit\n            units_remaining -= units_purchased\n        else:\n            total_cost += units_remaining * cost_per_unit\n            units_remaining = 0\n    return round(total_cost, 2)", "deterministic": true}, "diagnostic_checks": [{"rule_id": "fic_fifo_cogs_001", "name": "Units Sold Type Check", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['units_sold'], int)", "applies_to": [], "description": "The 'units_sold' input must be an integer."}, {"rule_id": "fic_fifo_cogs_002", "name": "Units Sold Non-Negative", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['units_sold'] < 0", "applies_to": [], "description": "The number of units sold cannot be negative."}, {"rule_id": "fic_fifo_cogs_003", "name": "Purchase Costs List Type", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['purchase_costs'], list)", "applies_to