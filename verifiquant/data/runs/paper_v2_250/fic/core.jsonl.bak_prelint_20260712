piti", "type": "number", "unit": "currency_per_month", "description": "The total monthly PITI payment."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    principal = inputs['principal']\n    annual_interest_rate = inputs['annual_interest_rate']\n    loan_term_years = inputs['loan_term_years']\n    annual_tax = inputs['annual_tax']\n    annual_insurance = inputs['annual_insurance']\n    monthly_interest_rate = annual_interest_rate / 12\n    num_payments = loan_term_years * 12\n    if monthly_interest_rate > 0:\n        monthly_principal_and_interest = principal * monthly_interest_rate / (1 - (1 + monthly_interest_rate) ** (-num_payments))\n    else:\n        monthly_principal_and_interest = principal / num_payments\n    monthly_tax = annual_tax / 12\n    monthly_insurance = annual_insurance / 12\n    total_monthly_piti = monthly_principal_and_interest + monthly_tax + monthly_insurance\n    return total_monthly_piti", "deterministic": true}, "diagnostic_checks": [{"rule_id": "piti_e1", "name": "Principal must be positive", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['principal'] <= 0", "applies_to": ["principal"], "description": "The principal loan amount must be a positive value."}, {"rule_id": "piti_e2", "name": "Annual interest rate must be non-negative", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['annual_interest_rate'] < 0", "applies_to": ["annual_interest_rate"], "description": "The annual interest rate cannot be negative."}, {"rule_id": "piti_e3", "name": "Loan term must be a positive whole number of years", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "not isinstance(inputs['loan_term_years'], int) or inputs['loan_term_years'] <= 0", "applies_to": ["loan_term_years"], "d