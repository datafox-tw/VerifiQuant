": [{"label": "Decimal - DEFAULT", "value": "decimal", "is_default": true}, {"label": "Percent", "value": "percent", "is_default": false, "transform_spec": {"patch_type": "result_postprocess", "result_expr": "result * 100.0", "max_expr_nodes": 6, "invariant": "result_new == result_old * 100.0", "affected_inputs": []}}], "i_level": "soft", "assumption_if_not_clarified": "Decimal", "impact_scope": "output_interpretation"}], "inputs": [{"name": "payment", "type": "number", "required": true, "description": "The payment amount per period.", "unit": null, "aliases": []}, {"name": "interest_rate", "type": "number", "required": true, "description": "The interest rate per period as a decimal (e.g., 0.05 for 5%).", "unit": null, "aliases": []}, {"name": "periods", "type": "integer", "required": true, "description": "The total number of periods.", "unit": null, "aliases": []}, {"name": "annuity_due", "type": "boolean", "required": true, "description": "If True, calculates the future value for an annuity due. If False, for an ordinary annuity.", "unit": null, "aliases": []}], "output": {"name": "future_value", "type": "number", "unit": null, "description": "The future value of the annuity."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    payment = inputs['payment']\n    interest_rate = inputs['interest_rate']\n    periods = inputs['periods']\n    annuity_due = inputs['annuity_due']\n    if interest_rate == 0:\n        future_value = payment * periods\n    else:\n        factor = (1 + interest_rate) ** periods\n        future_value = payment * (factor - 1) / interest_rate\n        if annuity_due:\n            future_value *= 1 + interest_rate\n    return future_value", "deterministic": true}, "diagnostic_checks": [{"rule_id": "fv_annuity_001", "name": "Payment Type Check", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['payment'], (int, float))", "applies_to": [], "description": "The 'payment' input must be a number (integer or float)."}, {"rule_id": "fv_annuity_002", "name": "Interest Rate Type Check", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['interest_rate'], (int, float))", "applies_to": [], "description": "The 'interest_rate' input must be a number (integer or float)."}, {"rule_id": "fv_annuity_003", "name": "Periods Type Check", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['periods'], int)", "applies_to": [], "description": "The 'periods' input must be an integer."}, {"rule_id": "fv_annuity_004", "name": "Annuity Due Type Check", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['annuity_due'], bool)", "applies_to": [], "description": "The 'annuity_due' input must be a boolean (True or False)."}, {"rule_id": "fv_annuity_005", "name": "Payment Positive Check", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['payment'] <= 0", "applies_to": [], "description": "The payment amount per period must be a positive value."}, {"rule_id": "fv_annuity_006", "name": "Interest Rate Non-Negative Check", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['interest_rate'] < 0", "applies_to": [], "description": "The interest rate per period cannot be negative."}, {"rule_id": "fv_annuity_007", "name": "Periods Positive Check", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['periods'] <= 0", "applies_to": [], "description": "The total number of periods must be a positive integer."}, {"rule_id": "fv_annuity_008", "name": "Interest Rate Plausibility Check", "check_type": "deterministic", "diagnostic_type": "E", "severity": "alert", "predicate_mode": "violation", "expression": "inputs['interest_rate'] > 1.0", "applies_to": [], "description": "The interest rate is typically provided as a decimal (e.g., 0.06 for 6%). A value greater than 1.0 suggests a possible error where a percentage was entered instead of a decimal."}], "execution_smoke_test": {"ok": true, "error": null, "autofix_applied": false, "lint_fixes": [], "effective_code": "def compute(inputs):\n    payment = inputs['payment']\n    interest_rate = inputs['interest_rate']\n    periods = inputs['periods']\n    annuity_due = inputs['annuity_due']\n    if interest_rate == 0:\n        future_value = payment * periods\n    else:\n        factor = (1 + interest_rate) ** periods\n        future_value = payment * (factor - 1) / interest_rate\n        if annuity_due:\n            future_value *= 1 + interest_rate\n    return future_value"}, "article_title": "Annuity", "article_doc_id": 4507, "article_content_excerpt": "# Guide to Annuities: What They Are, Types, and How They Work\n\nDefinition\n\nAn annuity is a contract that's issued and distributed by an insurance company and bought by individuals. The insurance company pays a fixed or variable income stream to the purchaser.\n\nAn annuity is a contract that's issued and distributed by an insurance company and bought by individuals. The insurance company pays out a fixed or variable income stream to the purchaser beginning right away or at some time in the future in exchange for premiums they've paid. It's not the same as a life insurance policy that only pays benefits when the insured dies. \n\nPeople invest in or purchase annuities by making monthly premium payments or payments. The holding institution issues a stream of payments for a specified period of time or for the remainder of the annuitant's life. \n\nAnnuities are used primarily for retirement income purposes. They can help individuals address the risk of outliving their savings. \n\n### Key Takeaways\n\n * Annuities are financial products that offer a guaranteed income stream and are usually bought by retirees.\n * The accumulation phase is the first stage of an annuity during which investors fund the product with a lump-sum payment or periodic payments.\n * The annuitant begins receiving payments after the annuitization period for a fixed period or the rest of their life.\n * Annuities can be structured into various types of instruments, giving investors flexibility.\n * An annuity can be categorized as immediate or deferred, and fixed, variable, or indexed.\n\n:max_bytes\\(150000\\):strip_icc\\(\\)/Term-a-annuity-d4d5906faea940828244ef128f416cc5.jpg)\n\nInvestopedia / Ryan Oakley\n\n## How an Annuity Works \n\n### Purpose \n\nAnnuities are designed to provide a steady cash flow for people during their retirement years to alleviate the fear of outliving their assets. These assets may not be enough to sustain their , however, so some investors may turn to an insurance company or other financial institution to purchase an annuity contract. \n\nThese financial products are appropriate for investors, known as , who want stable, guaranteed retirement income. Invested cash is illiquid and subject to withdrawal penalties so it's generally not recommended that younger individuals or those with needs use this financial product. \n\n### Phases \n\nAn annuity has different phases: \n\n * The or period when an annuity is being funded and before payouts begin and the money invested grows on a tax-deferred basis\n * The which kicks in after payments to the investor begin\n\n### Immediate vs. Deferred \n\nAnnuities can be immediate or deferred. \n\nImmediate annuities are often purchased by individuals of any age who have received a large lump sum of money such as a settlement or lottery win and prefer to exchange that money for cash flows into the future. Deferred annuities are structured to grow on a basis and provide annuitants with guaranteed income that begins on a date they specify. \n\n### Regulation \n\nVariable annuities are regulated by the and state insurance commissioners. Fixed annuities aren't securities so they're regulated by state insurance commissioners rather than the SEC. Indexed annuities are normally regulated by a state insurance commissioner. They're regulated by the SEC as well if they're registered as securities, \n\nThe also regulates variable and registered indexed annuities.\n\nAgents or brokers selling annuities must hold a state-issued life insurance license as well as a securities license in the case of variable annuities. These agents or brokers typically earn a commission based on the notional value of the annuity contract. \n\n### Important: \n\nAnnuities often come with complicated tax considerations so it's important to understand how they work. Consult with a professional before you purchase an annuity contract.\n\n## Other Considerations \n\n### Surrender Period and Withdrawals \n\nAnnuities usually have a . Annuitants can't take withdrawals during this time without\n...[truncated]"}
{"fic_id": "fic_article_514", "name": "Kurtosis", "short_description": "Calculates the excess kurtosis of a given dataset, indicating the 'tailedness' of its probability distribution relative to a normal distribution.", "domain": "risk_management", "topic": "risk_metrics", "topic_extension": false, "version": "v2", "source_meta": {"function_id": "article-514", "source": "FinanceReasoning-test-196", "question_id": "test-2160", "difficulty": 5.075173815233827, "level": "hard", "execution_smoke_ok": false, "execution_autofix_applied": false, "execution_smoke_error": "Dataset must contain at least four data points.", "normalization_version": "ast_v1_docstring_strip", "code_sanity_ok": true, "ast_exact_hash": "4726cc51ec3d313335d51d85e50bcb32e6802ecdc4cc99d264a2dced95f7af8c", "is_duplicate_kernel": false, "duplicate_of": null}, "selection_hints": ["statistical measure of tailedness", "fat tails", "extreme values", "distribution shape", "investment risk", "risk assessment", "financial data analysis", "stock returns"], "semantic_hints": [{"id": "kurtosis_type", "ambiguity_type": "definition_basis", "trigger_signal": "user refers to kurtosis without specifying 'excess' or 'raw'", "clarification_question": "Should kurtosis be reported as raw kurtosis or excess kurtosis (relative to a normal distribution)?", "options": [{"label": "Excess Kurtosis (normal = 0) - DEFAULT", "value": "excess_kurtosis", "is_default": true}, {"label": "Raw Kurtosis (normal = 3)", "value": "raw_kurtosis", "is_default": false, "transform_spec": {"patch_type": "result_postprocess", "result_expr": "result + 3", "max_expr_nodes": 6, "invariant": "result_new == result_old + 3", "affected_inputs": []}}], "i_level": "soft", "assumption_if_not_clarified": "Excess kurtosis (where a normal distribution has a kurtosis of 0)", "impact_scope": "output_interpretation"}], "inputs": [{"name": "data", "type": "array[number]", "required": true, "description": "A list of numerical data points (e.g., daily returns) for which kurtosis is to be computed.", "unit": "percent", "aliases": ["returns", "values", "dataset", "series"]}], "output": {"name": "kurtosis", "type": "number", "unit": null, "description": "The calculated excess kurtosis of the dataset, representing the 'tailedness' of the distribution. Positive values indicate fatter tails, negative values indicate lighter tails compared to a normal distribution."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    data = inputs['data']\n    n = len(data)\n    if n < 4:\n        raise ValueError('Dataset must contain at least four data points.')\n    mean = sum(data) / n\n    s2 = sum(((x - mean) ** 2 for x in data))\n    s4 = sum(((x - mean) ** 4 for x in data))\n    if s2 == 0:\n        raise ValueError('Variance should not be zero.')\n    m2 = s2 / n\n    m4 = s4 / n\n    kurtosis = m4 / m2 ** 2 - 3\n    return round(kurtosis, 2)", "deterministic": true}, "diagnostic_checks": [{"rule_id": "input_data_missing", "name": "Data input is required", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "'data' not in inputs or inputs['data'] is None", "applies_to": ["data"], "description": "The 'data' input cannot be missing or null."}, {"rule_id": "input_data_type", "name": "Data input must be a list", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "not isinstance(inputs.get('data'), list)", "applies_to": ["data"], "description": "The 'data' input must be a list of numerical values."}, {"rule_id": "input_data_elements_numeric", "name": "All data points must be numeric", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "all(isinstance(x, (int, float)) for x in inputs.get('data', []))", "applies_to": ["data"], "description": "Each element in the 'data' list must be an integer or a float."}, {"rule_id": "data_minimum_length", "name": "Dataset must contain at least 4 data points", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "len(inputs['data']) < 4", "applies_to": ["data"], "description": "Kurtosis calculation requires a minimum of 4 data points in the dataset."}, {"rule_id": "data_variance_non_zero", "name": "Data points cannot all be identical", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "len(set(inputs['data'])) <= 1", "applies_to": ["data"], "description": "All data points in the dataset cannot be identical, as this results in zero variance, making kurtosis undefined."}, {"rule_id": "kurtosis_plausibility_range", "name": "Kurtosis value within plausible range", "check_type": "deterministic", "diagnostic_type": "E", "severity": "alert", "predicate_mode": "violation", "expression": "compute(inputs) < -3 or compute(inputs) > 50", "applies_to": ["data"], "description": "Excess kurtosis values typically range, but values outside of -3 to 50 may indicate data issues or extreme distributions. A value of -3 is the theoretical minimum for excess kurtosis (for a discrete two-point distribution). Very high values (e.g., >50) are rare for financial data."}], "execution_smoke_test": {"ok": false, "error": "Dataset must contain at least four data points.", "autofix_applied": false, "lint_fixes": [], "effective_code": "def compute(inputs):\n    data = inputs['data']\n    n = len(data)\n    if n < 4:\n        raise ValueError('Dataset must contain at least four data points.')\n    mean = sum(data) / n\n    s2 = sum(((x - mean) ** 2 for x in data))\n    s4 = sum(((x - mean) ** 4 for x in data))\n    if s2 == 0:\n        raise ValueError('Variance should not be zero.')\n    m2 = s2 / n\n    m4 = s4 / n\n    kurtosis = m4 / m2 ** 2 - 3\n    return round(kurtosis, 2)"}, "article_title": "Kurtosis", "article_doc_id": 918, "article_content_excerpt": "# Kurtosis: Definition, Types, and Importance\n\nDefinition\n\nKurtosis is a statistical measure used to describe a characteristic of a dataset.\n\n## What Is Kurtosis? \n\nKurtosis is a statistical measure used to describe a characteristic of a dataset. When normally distributed data is plotted on a graph, it generally takes the form of a bell. This is called the bell curve. The plotted data that are farthest from the of the data usually form the tails on each side of the curve. Kurtosis indicates how much data resides in the tails. \n\n### Key Takeaways\n\n * Kurtosis describes the “fatness” of the tails found in probability distributions.\n * There are three kurtosis categories: mesokurtic (normal), platykurtic (less than normal), and leptokurtic (more than normal).\n * Kurtosis risk is a measurement of how often an investment’s price moves dramatically.\n * A curve’s kurtosis characteristic tells you how much kurtosis risk there is for the investment you’re evaluating.\n\n:max_bytes\\(150000\\):strip_icc\\(\\)/kurtosis.asp-final-1fc7ca0658304918ab7a5890691eb99f.png)\n\nJessica Olah / Investopedia\n\n## Understanding Kurtosis \n\nKurtosis is a measure of the combined weight of a distribution’s tails relative to the center of the distribution curve (the mean). For example, when a set of approximately normal data is graphed via a histogram, it shows a bell peak, with most of the data residing within three standard deviations (plus or minus) of the mean. However, when high kurtosis is present, the tails extend farther than the three standard deviations of the normal bell-curved distribution. \n\nKurtosis is sometimes confused with a measure of the peakedness of a distribution. However, kurtosis is a measure that describes the shape of a distribution’s tails in relation to its overall shape. A distribution can be sharply peaked with low kurtosis, and a distribution can have a lower peak with high kurtosis. Thus, kurtosis measures “tailedness,” not “peakedness.” \n\nDistributions with a large kurtosis have more tail data than normally distributed data, which appears to bring the tails in toward the mean. Distributions with low kurtosis have fewer tail data, which appears to push the tails of the bell curve away from the mean. \n\nFor , high kurtosis of the return distribution curve implies that there have been many price fluctuations in the past (positive or negative) away from the average returns for the investment. So, an investor might experience extreme price fluctuations with an investment with high kurtosis. This phenomenon is known as kurtosis risk. \n\n## Formula and Calculation of Kurtosis \n\n### Calculating with Spreadsheets \n\nThere are several different methods for calculating kurtosis. The simplest way is to use the Excel or Google Sheets formula. For instance, assume you have the following sample data: 4, 5, 6, 3, 4, 5, 6, 7, 5, and 8 residing in cells A1 through A10 on your spreadsheet. The spreadsheets use this formula for calculating kurtosis:\n\n\\begin{aligned}& \\frac { n ( n + 1 ) }{ (n - 1)(n - 2)(n - 3) } \\times \\Big ( \\sum \\frac { x_i - \\bar{x} }{ s } \\Big ) ^ 4 - \\frac { 3 (n - 1) ^ 2 }{ (n - 2)(n - 3)} \\\\\\\\\\end{aligned}\n\nHowever, we’ll use the following formula in Google Sheets, which calculates it for us, assuming the data resides in cells A1 through A10:\n\n\\begin{aligned}&= \\text{KURT(A1:A10)} \\\\\\\\\\end{aligned}\n\nThe result is a kurtosis of -0.1518, indicating the curve has lighter tails and is platykurtic. \n\n### Calculating by Hand \n\nCalculating kurtosis by hand is a lengthy endeavor, and takes several steps to get to the results. We’ll use new data points and limit their number to simplify the calculation. The new data points are 27, 13, 17, 57, 113, and 25. \n\n### Important: \n\nIt’s important to note that a sample size should be much larger than this; we are using six numbers to reduce the calculation steps. A good rule of thumb is to use 30% of your data for populations under 1,000. For larger populations, you can use 10%.\n\nFirst, you need t\n...[truncated]"}
{"fic_id": "fic_article_2316", "name": "Annual Percentage Rate (APR)", "short_description": "Calculates the Annual Percentage Rate (APR) for a loan based on total fees, interest, principal, and loan term in days, assuming simple interest.", "domain": "personal_finance", "topic": "loan_apr_calculation", "topic_extension": true, "version": "v2", "source_meta": {"function_id": "article-2316", "source": "FinanceReasoning-test-487", "question_id": "test-1704", "difficulty": 3.2188758248682006, "level": "medium", "execution_smoke_ok": true, "execution_autofix_applied": false, "normalization_version": "ast_v1_docstring_strip", "code_sanity_ok": true, "ast_exact_hash": "5eacc42ad9608392678d88f227a073724f5df2a11ccec71b3e22e2a589e9a820", "is_duplicate_kernel": false, "duplicate_of": null}, "selection_hints": ["Annual Percentage Rate", "APR calculation", "loan interest rate", "cost of borrowing", "simple interest rate", "yearly interest", "borrowing cost"], "semantic_hints": [{"id": "output_scale", "ambiguity_type": "unit_scale", "trigger_signal": "question asks for percentage, FIC outputs decimal (or vice versa)", "clarification_question": "Should the answer be expressed as a decimal (0.08) or percent (8.0)?", "options": [{"label": "Percentage (e.g., 8.0 for 8%) — DEFAULT", "value": "percent", "is_default": true}, {"label": "Decimal (e.g., 0.08 for 8%)", "value": "decimal", "is_default": false, "transform_spec": {"patch_type": "result_postprocess", "result_expr": "result / 100.0", "max_expr_nodes": 6, "invariant": "result_new == result_old / 100.0", "affected_inputs": []}}], "i_level": "soft", "assumption_if_not_clarified": "Percentage (output is multiplied by 100)", "impact_scope": "output_interpretation"}, {"id": "fees_inclusion", "ambiguity_type": "input_binding", "trigger_signal": "the 'fees' component's specific inclusions or exclusions are not explicitly detailed", "clarification_question": "Are all relevant charges, including lender-specific or legally excludable fees,