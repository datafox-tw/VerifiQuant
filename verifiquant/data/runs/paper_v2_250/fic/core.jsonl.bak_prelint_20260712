"label": "Modified Duration", "value": "modified", "is_default": false, "transform_spec": {"patch_type": "result_postprocess", "result_expr": "result / (1 + yield_rate)", "max_expr_nodes": 10, "invariant": "result_new * (1 + yield_rate) == result_old", "affected_inputs": ["yield_rate"]}}], "i_level": "soft", "assumption_if_not_clarified": "Macaulay Duration is requested.", "impact_scope": "output_interpretation"}], "inputs": [{"name": "cash_flows", "type": "array[number]", "required": true, "description": "A list of future cash flows, including periodic coupon payments and the bond's par value at maturity. The list should be structured with cash flows in chronological order.", "unit": null, "aliases": []}, {"name": "yield_rate", "type": "number", "required": true, "description": "The bond's yield rate or discount rate per period.", "unit": "decimal", "aliases": []}, {"name": "periods", "type": "integer", "required": true, "description": "The total number of periods until the bond's maturity.", "unit": null, "aliases": []}], "output": {"name": "mac_duration", "type": "number", "unit": "years", "description": "The Macaulay duration of the bond, representing the weighted average time until cash flows are received."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    cash_flows = inputs['cash_flows']\n    yield_rate = inputs['yield_rate']\n    periods = inputs['periods']\n    discounted_cf = [cf / (1 + yield_rate) ** t for t, cf in enumerate(cash_flows, start=1)]\n    total_present_value = sum(discounted_cf)\n    mac_duration = sum((t * cf_pv / total_present_value for t, cf_pv in enumerate(discounted_cf, start=1)))\n    return round(mac_duration, 2)", "deterministic": true}, "diagnostic_checks": [{"rule_id": "md_i001", "name": "Cash Flows Not Empty", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "len(inputs['cash_flows']) == 0", "applies_to": [], "des