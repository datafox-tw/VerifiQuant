ions": [{"label": "As a direct numerical score (e.g., 4.5) - DEFAULT", "value": "numerical_score", "is_default": true}, {"label": "Mapped to a corresponding letter credit rating (e.g., 'BBB' or 'B+')", "value": "letter_grade_interpretation", "is_default": false}], "i_level": "soft", "assumption_if_not_clarified": "The output represents a direct numerical score.", "impact_scope": "output_interpretation"}], "inputs": [{"name": "rating_proportions", "type": "dict[string,number]", "required": true, "description": "A JSON object/dictionary where keys are credit ratings and values are portfolio proportions as fractions of 1.", "unit": null, "aliases": ["bond_ratings_distribution", "credit_allocation"]}, {"name": "credit_rating_map", "type": "dict[string,number]", "required": true, "description": "A JSON object/dictionary mapping each credit rating label to its numerical score.", "unit": null, "aliases": ["rating_value_scale", "numerical_ratings"]}], "output": {"name": "weighted_average_rating", "type": "number", "unit": "numerical_score", "description": "The calculated weighted average credit rating as a numerical score, indicating overall credit quality."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    rating_proportions = inputs['rating_proportions']\n    credit_rating_map = inputs['credit_rating_map']\n    for rating_key in rating_proportions:\n        if rating_key not in credit_rating_map:\n            raise ValueError(f\"Credit rating '{rating_key}' from proportions is not defined in the credit_rating_map.\")\n    weighted_sum = sum((credit_rating_map[rating] * proportion for rating, proportion in rating_proportions.items()))\n    total_weight = sum(rating_proportions.values())\n    if total_weight == 0:\n        raise ValueError('Total weight of proportions cannot be zero.')\n    weighted_average_rating = weighted_sum / total_weight\n    return round(weighted_average_rating, 2)", "deterministic": true}, "diagnostic_checks": [{"rule_id": "rp_type_structure", "name": "Rating Proportions Structure", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "not (isinstance(inputs['rating_proportions'], dict) and all(isinstance(v, (int, float)) for v in inputs['rating_proportions'].values()))", "applies_to": [], "description": "The 'rating_proportions' input must be a dictionary where all values are numbers representing proportions."}, {"rule_id": "crm_type_structure", "name": "Credit Rating Map Structure", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "not (isinstance(inputs['credit_rating_map'], dict) and all(isinstance(v, (int, float)) for v in inputs['credit_rating_map'].values()))", "applies_to": [], "description": "The 'credit_rating_map' input must be a dictionary where all values are numbers representing numerical credit scores."}, {"rule_id": "rp_non_negative", "name": "Non-negative Proportions", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "any(prop < 0 for prop in inputs['rating_proportions'].values())", "applies_to": [], "description": "All proportions in 'rating_proportions' must be non-negative."}, {"rule_id": "total_weight_non_zero", "name": "Non-zero Total Weight", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "sum(inputs['rating_proportions'].values()) == 0", "applies_to": [], "description": "The sum of proportions in 'rating_proportions' cannot be zero to avoid division by zero."}, {"rule_id": "rating_key_mapping", "name": "Credit Rating Key Mismatch", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "any(rating_key not in inputs['credit_rating_map'] for rating_key in inputs['rating_proportions'])", "applies_to": [], "description": "All credit rating keys in 'rating_proportions' must have a corresponding numerical mapping in 'credit_rating_map'."}, {"rule_id": "total_proportion_sum", "name": "Total Proportions Sum to One", "check_type": "deterministic", "diagnostic_type": "E", "severity": "alert", "predicate_mode": "violation", "expression": "abs(sum(inputs['rating_proportions'].values()) - 1.0) > 1e-6", "applies_to": [], "description": "The sum of proportions in 'rating_proportions' should ideally sum to 1 (or 100%). Large deviations may indicate incorrect input or rounding issues."}], "execution_smoke_test": {"ok": true, "error": null, "autofix_applied": false, "lint_fixes": [], "effective_code": "def compute(inputs):\n    rating_proportions = inputs['rating_proportions']\n    credit_rating_map = inputs['credit_rating_map']\n    for rating_key in rating_proportions:\n        if rating_key not in credit_rating_map:\n            raise ValueError(f\"Credit rating '{rating_key}' from proportions is not defined in the credit_rating_map.\")\n    weighted_sum = sum((credit_rating_map[rating] * proportion for rating, proportion in rating_proportions.items()))\n    total_weight = sum(rating_proportions.values())\n    if total_weight == 0:\n        raise ValueError('Total weight of proportions cannot be zero.')\n    weighted_average_rating = weighted_sum / total_weight\n    return round(weighted_average_rating, 2)"}, "article_title": "Weighted Average Credit Rating", "article_doc_id": 4846, "article_content_excerpt": "# Weighted Average Credit Rating (WACR)\n\n## What Is a Weighted Average Credit Rating (WACR)? \n\nThe weighted average credit rating (WACR) relates to the weighted average rating regarding all bonds in a . This rating procedure provides investors with an idea as to a fund's credit quality. It also helps to identify the overall risk involved with a bond portfolio. The lower the weighted average credit rating, the riskier a bond fund is. The weighted average credit rating is designated in letter rating form, including AAA, BBB, or CCC. \n\n### Key Takeaways\n\n * A weighted average credit rating provides investors with insight into a fund's overall credit quality, designated as AAA, BBB, or CCC.\n * The weighted-average credit rating is calculated by considering the proportion of the value of each individual credit rating and noting it as a percentage of the entire portfolio thereby producing the average credit rating. \n * Weighted average credit ratings are questioned by some as they may cause confusion for investors who don't thoroughly understand the rating.\n * Linear factors are also used to determine a fund’s credit quality and are assigned to a rating level based on default probability. \n\n## How a Weighted Average Credit Rating (WACR) Works \n\nHow a weighted average credit rating is tabulated varies throughout the financial industry. In general, the weighted average credit rating takes into consideration the proportion of the value of each and considers it as a percentage of the total portfolio. With individual rating weights the fund can determine the average credit rating. \n\n### Important: \n\nWith a weighted average credit rating, investors can uncover the true credit quality of a bond fund.\n\n## Special Considerations \n\nThe weighted-average credit rating is not the only statistic that investors have access to when understanding the credit quality of a fund. Statistical reporting companies may also integrate a linear factor into weighted average credit rating calculations. Similar in concept to standard weighted average calculations, this methodology identifies the proportional weight of the value of each rating level. \n\nWith linear factor calculations, a linear factor is assigned to each rating level based on the rating probability. An average linear factor is determined by the proportional credit ratings of the bonds in the portfolio. The weighted-average credit rating is then determined by its corresponding linear factor. \n\n## Criticism of Weighted Average Credit Ratings \n\nThis type of rating is not without controversy. The weighted-average credit rating process has been disputed in the bond fund industry as a result of the potential for investor confusion. A weighted average rating methodology can take into consideration all of the potential rating classifications a fund can invest in. Therefore, the fund may not hold any bonds in the specified weighted average rating category and this can result in confusion by those who see the tabulated figures. \n\n## Example of a Weighted Average Credit Rating (WACR) \n\nA bond with 25% of its value in AAA, 25% in BBB and 50% in CCC could have an average credit rating of B+ which is between BBB and CCC. This may not necessarily provide a good representation to investors since the fund does not hold any B+ bonds. For this reason, most bond funds choose to provide a scale with weightings by credit rating in their marketing materials. This helps investors to understand the concentration of by rating and not just look to the results of the weighted average credit rating. \n\nThe Vanguard Long-Term Corporate Bond ETF is a large bond fund with more than $6 billion in assets. The fund does not provide a weighted average credit rating in its marketing materials or fund reporting. Instead, it includes the following scale which shows its dispersion as of December 31, 2020.﻿﻿﻿ \n \n<table> \n<tr> \n<td>\n\nU.S. Govt.\n</td> \n<td>\n\n0.3%\n</td> </tr> \n<tr> \n<td>\n\nAaa\n</td> \n<td>\n\n2.7%\n</td> </tr> \n<tr> \n<td>\n\nAa\n</t\n...[truncated]"}
{"fic_id": "fic_article_891", "name": "Matching Orders", "short_description": "Calculates the total executed quantity of matched buy and sell orders using a First-In-First-Out (FIFO) algorithm, prioritizing orders by price-time.", "domain": "financial_markets", "topic": "stock_market_analysis", "topic_extension": false, "version": "v2", "source_meta": {"function_id": "article-891", "source": "FinanceReasoning-test-188", "question_id": "test-2102", "difficulty": 4.605170185988091, "level": "hard", "execution_smoke_ok": true, "execution_autofix_applied": false, "normalization_version": "ast_v1_docstring_strip", "code_sanity_ok": true, "ast_exact_hash": "b0920b9a88d1701c9f7ac592d5064f41d7fc34ffd524356d06d1d6daf08b7d96", "is_duplicate_kernel": false, "duplicate_of": null}, "selection_hints": ["order matching", "FIFO", "First-In-First-Out", "buy orders", "sell orders", "executed quantity", "trade execution", "stock exchange"], "semantic_hints": [{"id": "order_matching_algorithm", "ambiguity_type": "calculation_method", "trigger_signal": "order matching algorithm not explicitly stated or implied to be FIFO", "clarification_question": "Which order matching algorithm should be used to calculate the executed quantity?", "options": [{"label": "FIFO (First-In-First-Out) - DEFAULT", "value": "fifo", "is_default": true}, {"label": "Pro-Rata", "value": "pro_rata", "is_default": false, "transform_spec": {"patch_type": "result_postprocess", "result_expr": "result * (1 + 0.25)", "max_expr_nodes": 9, "invariant": "result_new == result_old * (1 + 0.25)", "affected_inputs": []}}], "i_level": "hard", "assumption_if_not_clarified": "FIFO (First-In-First-Out) algorithm", "impact_scope": "output_interpretation"}], "inputs": [{"name": "buy_orders", "type": "array[object]", "required": true, "description": "A JSON array of buy order objects. Each object has numeric/integer quantity and price fields.", "unit": null, "aliases": ["bids"]}, {"name": "sell_orders", "type": "array[object]", "required": true, "description": "A JSON array of sell order objects. Each object has numeric/integer quantity and price fields.", "unit": null, "aliases": ["asks"]}], "output": {"name": "total_executed_quantity", "type": "integer", "unit": null, "description": "The total number of shares executed through matched orders based on the FIFO principle."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    buy_orders = [order.copy() for order in inputs['buy_orders']]\n    sell_orders = [order.copy() for order in inputs['sell_orders']]\n    matches_quantities = []\n    buy_index, sell_index = (0, 0)\n    while buy_index < len(buy_orders) and sell_index < len(sell_orders):\n        buy_order = buy_orders[buy_index]\n        sell_order = sell_orders[sell_index]\n        if buy_order['price'] >= sell_order['price']:\n            match_quantity = min(buy_order['quantity'], sell_order['quantity'])\n            matches_quantities.append(match_quantity)\n            buy_order['quantity'] -= match_quantity\n            sell_order['quantity'] -= match_quantity\n            if buy_order['quantity'] == 0:\n                buy_index += 1\n            if sell_order['quantity'] == 0:\n                sell_index += 1\n        else:\n            break\n    total_executed_quantity = sum(matches_quantities)\n    return total_executed_quantity", "deterministic": true}, "diagnostic_checks": [{"rule_id": "buy_orders_list_type_f", "name": "Buy Orders must be a list", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs.get('buy_orders'), list)", "applies_to": [], "description": "The 'buy_orders' input must be provided as a list."}, {"rule_id": "sell_orders_list_type_f", "name": "Sell Orders must be a list", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs.get('sell_orders'), list)", "applies_to": [], "description": "The 'sell_orders' input must be provided as a list."}, {"rule_id": "buy_order_item_structure_f", "name": "Buy order items must have quantity and price", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "all(isinstance(item, dict) and 'quantity' in item and 'price' in item for item in inputs.get('buy_orders', []))", "applies_to": [], "description": "Each buy order in the 'buy_orders' list must be a dictionary containing 'quantity' and 'price' keys."}, {"rule_id": "sell_order_item_structure_f", "name": "Sell order items must have quantity and price", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "all(isinstance(item, dict) and 'quantity' in item and 'price' in item for item in inputs.get('sell_orders', []))", "applies_to": [], "description": "Each sell order in the 'sell_orders' list must be a dictionary containing 'quantity' and 'price' keys."}, {"rule_id": "buy_order_quantity_positive_e", "name": "Buy order quantities must be positive", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "any(item.get('quantity', 0) <= 0 for item in inputs.get('buy_orders', []))", "applies_to": [], "description": "All 'quantity' values in 'buy_orders' must be strictly positive."}, {"rule_id": "sell_order_quantity_positive_e", "name": "Sell order quantities must be positive", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "any(item.get('quantity', 0) <= 0 for item in inputs.get('sell_orders', []))", "applies_to": [], "description": "All 'quantity' values in 'sell_orders' must be strictly positive."}, {"rule_id": "buy_orders_price_sorted_e", "name": "Buy orders must be sorted by price descending", "check_type": "deterministic", "diagnostic_type": "E", "severity": "alert", "predicate_mode": "violation", "expression": "any(inputs['buy_orders'][i]['price'] < inputs['buy_orders'][i+1]['price'] for i in range(len(inputs['buy_orders']) - 1))", "applies_to": [], "description": "The 'buy_orders' list is expected to be sorted in descending order by 'price' for correct FIFO behavior based on implicit prioritization."}], "execution_smoke_test": {"ok": true, "error": null, "autofix_applied": false, "lint_fixes": [], "effective_code": "def compute(inputs):\n    buy_orders = [order.copy() for order in inputs['buy_orders']]\n    sell_orders = [order.copy() for order in inputs['sell_orders']]\n    matches_quantities = []\n    buy_index, sell_index = (0, 0)\n    while buy_index < len(buy_orders) and sell_index < len(sell_orders):\n        buy_order = buy_orders[buy_index]\n        sell_order = sell_orders[sell_index]\n        if buy_order['price'] >= sell_order['price']:\n            match_quantity = min(buy_order['quantity'], sell_order['quantity'])\n            matches_quantities.append(match_quantity)\n            buy_order['quantity'] -= match_quantity\n            sell_order['quantity'] -= match_quantity\n            if buy_order['quantity'] == 0:\n                buy_index += 1\n            if sell_order['quantity'] == 0:\n                sell_index += 1\n        else:\n            break\n    total_executed_quantity = sum(matches_quantities)\n    return total_executed_quantity"}, "article_title": "Matching Orders", "article_doc_id": 1640, "article_content_excerpt": "# Matching Orders: What They Are, How They Work, and Examples\n\n## What Are Matching Orders? \n\nMatching orders is the process by which a securities pairs one or more unsolicited buy orders to one or more sell orders to make trades. This can be contrasted with (RFQ) in a security to proceed with a trade. \n\nIf one investor wants to buy a quantity of stock and another wants to sell the same quantity at the same price, their orders match, and a transaction is effected. The work of pairing these orders is the process of order matching whereby exchanges identify buy orders, or , with corresponding sell orders, or , to execute them. Over the past decade, this process has become almost entirely automated. \n\n### Key Takeaways\n\n * Matching orders is the process of identifying and effecting a trade between equal and opposite requests for a security (i.e., a buy and a sale at the same price).\n * Order matching is how many exchanges pair buyers and sellers at compatible prices for efficient and orderly trading.\n * Over the past decade, this process has become almost entirely automated.\n\n## How Matching Orders Works \n\nMatching the orders of buyers and sellers is the primary work of specialists and in the exchanges. The matches happen when compatible buy orders and sell orders for the same are submitted in close proximity in price and time. \n\nGenerally, a buy order and a sell order are compatible if the maximum price of the buy order matches or exceeds the minimum price of the sell order. From there, the computerized, order-matching systems of different exchanges use a variety of methods to prioritize orders for matching. \n\n### Fast Fact: \n\nToday, most exchanges match using computer algorithms; but historically, brokers matched orders through face-to-face interactions on a trading floor in an open-outcry auction.\n\nQuick, accurate order matching is a critical component of an exchange. Investors, particularly active investors and , will look for ways to minimize inefficiencies in trading from every possible source. A slow order-matching system may cause buyers or sellers to execute trades at less-than-ideal prices, eating into investors’ profits. If some order-matching protocols tend to favor buyers, and others favor sellers, these methods become exploitable. \n\nThis is one of the areas where (HFT) was able to improve efficiency. Exchanges aim to prioritize trades in a way that benefits buyers and sellers equally so as to maximize order volume—the lifeblood of the exchange. \n\n## Popular Algorithms for Matching Orders \n\nAll major markets have transitioned to electronic matching. Each securities exchange uses its own specific algorithm to match orders. Broadly, they fall under two categories: (FIFO) and . \n\n### FIFO \n\nUnder a basic FIFO algorithm, or price-time-priority algorithm, the earliest active buy order at the highest price takes priority over any subsequent order at that price, which in turn takes priority over any active buy order at a lower price. For example, if a buy order for 200 shares of stock at $90 per share precedes an order for 50 shares of the same stock at the same price, the system must match the entire 200-share order to one or more sell orders before beginning to match any portion of the 50-share order. \n\n### Pro-Rata \n\nUnder a basic pro-rata algorithm, the system prioritizes active orders at a particular price, proportional to the relative size of each order. For example, if both a 200-share buy order and a 50-share buy order at the same price are active when a compatible 200-share sell order arrives, the system will match 160 shares to the 200-share buy order and 40 shares to the 50-share buy order. \n\nSince the sell order is not large enough to fulfill both buy orders, the system will partially fill both. In this case, the pro-rata matching algorithm fills 80 percent of each order."}
