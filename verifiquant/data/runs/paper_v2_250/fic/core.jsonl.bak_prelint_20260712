 "value": "current_limits_applied", "is_default": true}, {"label": "No, it might be based on older rules or not fully compliant", "value": "potentially_non_compliant", "is_default": false}], "i_level": "soft", "assumption_if_not_clarified": "Itemized deductions correctly reflect current tax law limits, including mortgage interest.", "impact_scope": "input_binding"}], "inputs": [{"name": "itemized_deductions", "type": "number", "required": true, "description": "The total of all allowable itemized deductions, including mortgage interest.", "unit": "dollars", "aliases": []}, {"name": "standard_deduction", "type": "number", "required": true, "description": "The fixed amount allowed for the standard deduction.", "unit": "dollars", "aliases": []}, {"name": "tax_bracket", "type": "number", "required": true, "description": "The taxpayer's marginal tax rate expressed as a decimal (e.g., 0.24 for 24%).", "unit": null, "aliases": []}], "output": {"name": "tax_benefit", "type": "number", "unit": "dollars", "description": "The amount of tax saved by itemizing deductions instead of taking the standard deduction."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    itemized_deductions = inputs['itemized_deductions']\n    standard_deduction = inputs['standard_deduction']\n    tax_bracket = inputs['tax_bracket']\n    if itemized_deductions > standard_deduction:\n        tax_benefit = (itemized_deductions - standard_deduction) * tax_bracket\n    else:\n        tax_benefit = 0.0\n    return round(tax_benefit, 2)", "deterministic": true}, "diagnostic_checks": [{"rule_id": "input_itemized_deductions_non_negative", "name": "Itemized Deductions Non-Negative Check", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "validity", "expression": "inputs['itemized_deductions'] >= 0", "applies_to": ["itemized_deductions"], "description": "Itemized deductions must be a non-negative value."}, {"rule_id": "inpu