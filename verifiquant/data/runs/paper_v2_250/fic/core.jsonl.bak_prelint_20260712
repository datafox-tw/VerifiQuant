_changes = [ccp - pcp for ccp, pcp in zip(current_prices, prior_prices)]\n    absolute_price_changes = [abs(pc) for pc in price_changes]\n    if not price_changes or not absolute_price_changes:\n        return 0.0\n    pcs_ema = calculate_ema(price_changes, period1)\n    apc_ema = calculate_ema(absolute_price_changes, period1)\n    if not pcs_ema or not apc_ema:\n        return 0.0\n    pcds_ema = calculate_ema(pcs_ema, period2)\n    apcds_ema = calculate_ema(apc_ema, period2)\n    if not pcds_ema or not apcds_ema:\n        return 0.0\n    if apcds_ema[-1] == 0:\n        return 0.0\n    tsi = pcds_ema[-1] / apcds_ema[-1] * 100\n    return tsi", "deterministic": true}, "diagnostic_checks": [{"rule_id": "f001", "name": "Current Prices must be a list", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['current_prices'], list)", "applies_to": [], "description": "The 'current_prices' input must be a list of numerical values."}, {"rule_id": "f002", "name": "Prior Prices must be a list", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['prior_prices'], list)", "applies_to": [], "description": "The 'prior_prices' input must be a list of numerical values."}, {"rule_id": "f003", "name": "Period 1 must be an integer", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['period1'], int)", "applies_to": [], "description": "The 'period1' for the EMA calculation must be an integer."}, {"rule_id": "f004", "name": "Period 2 must be an integer", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['period2'], int)", "applies_to": [], "description": "The 'period2' for the EMA calculation must be an integer."}, {"rule_id": "f005", "name": "