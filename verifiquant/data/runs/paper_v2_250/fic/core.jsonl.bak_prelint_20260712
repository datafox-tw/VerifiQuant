sform_spec": {"patch_type": "result_postprocess", "result_expr": "result[-1]", "max_expr_nodes": 8, "invariant": "result_new == result_old[-1]", "affected_inputs": []}}], "i_level": "soft", "assumption_if_not_clarified": "Returns the complete time series of Negative Volume Index values.", "impact_scope": "output_interpretation"}], "inputs": [{"name": "prices", "type": "array[number]", "required": true, "description": "A list of prices or index levels at each time period (e.g., daily closing prices).", "unit": null, "aliases": []}, {"name": "volumes", "type": "array[number]", "required": true, "description": "A list of trading volumes corresponding to each time period.", "unit": null, "aliases": []}, {"name": "initial_nvi", "type": "number", "required": false, "description": "The initial starting value for the Negative Volume Index calculation, typically 1000.", "unit": null, "aliases": []}], "output": {"name": "nvi_series", "type": "array[number]", "unit": null, "description": "A list of Negative Volume Index (NVI) values for each time period, reflecting price movements during decreased volume days."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    prices = inputs['prices']\n    volumes = inputs['volumes']\n    initial_nvi = inputs.get('initial_nvi', 1000.0)\n    nvi_series = [initial_nvi]\n    for t in range(1, len(prices)):\n        if prices[t - 1] == 0:\n            new_nvi_value = nvi_series[-1]\n        elif volumes[t] < volumes[t - 1]:\n            price_change_percentage = (prices[t] - prices[t - 1]) / prices[t - 1]\n            new_nvi_value = nvi_series[-1] + price_change_percentage * nvi_series[-1]\n        else:\n            new_nvi_value = nvi_series[-1]\n        nvi_series.append(new_nvi_value)\n    return nvi_series", "deterministic": true}, "diagnostic_checks": [{"rule_id": "nvi_equal_length", "name": "Input lists must have equal length", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "len(inputs['prices']) != len(inputs['volumes'])", "applies_to": [], "description": "The lists of prices and volumes must have the same number of elements for a valid NVI calculation."}, {"rule_id": "nvi_min_length", "name": "Input lists must have at least two elements", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "len(inputs['prices']) < 2 or len(inputs['volumes']) < 2", "applies_to": [], "description": "NVI calculation requires at least two time periods (current and previous) to compute changes."}, {"rule_id": "nvi_positive_prices", "name": "Prices must be positive", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "any(p <= 0 for p in inputs['prices'])", "applies_to": [], "description": "Prices must be positive for meaningful percentage change calculations and to avoid division by zero."}, {"rule_id": "nvi_non_negative_volumes", "name": "Volumes must be non-negative", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "any(v < 0 for v in inputs['volumes'])", "applies_to": [], "description": "Trading volumes cannot be negative."}, {"rule_id": "nvi_prices_type", "name": "Prices must be a list of numbers", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['prices'], list) and all(isinstance(x, (int, float)) for x in inputs['prices'])", "applies_to": [], "description": "The 'prices' input must be a list where all elements are numbers (integers or floats)."}, {"rule_id": "nvi_volumes_type", "name": "Volumes must be a list of numbers", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['volumes'], list) and all(isinstance(x, (int, float)) for x in inputs['volumes'])", "applies_to": [], "description": "The 'volumes' input must be a list where all elements are numbers (integers or floats)."}, {"rule_id": "nvi_initial_nvi_positive", "name": "Initial NVI value must be a positive number", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs.get('initial_nvi', 1000.0) <= 0", "applies_to": [], "description": "The initial Negative Volume Index should be a positive value, as it serves as a baseline."}], "execution_smoke_test": {"ok": true, "error": null, "autofix_applied": false, "lint_fixes": [], "effective_code": "def compute(inputs):\n    prices = inputs['prices']\n    volumes = inputs['volumes']\n    initial_nvi = inputs.get('initial_nvi', 1000.0)\n    nvi_series = [initial_nvi]\n    for t in range(1, len(prices)):\n        if prices[t - 1] == 0:\n            new_nvi_value = nvi_series[-1]\n        elif volumes[t] < volumes[t - 1]:\n            price_change_percentage = (prices[t] - prices[t - 1]) / prices[t - 1]\n            new_nvi_value = nvi_series[-1] + price_change_percentage * nvi_series[-1]\n        else:\n            new_nvi_value = nvi_series[-1]\n        nvi_series.append(new_nvi_value)\n    return nvi_series"}, "article_title": "Negative Volume Index (NVI)", "article_doc_id": 5800, "article_content_excerpt": "# Negative Volume Index (NVI): Meaning, Overview, Calculations\n\n## What Is the Negative Volume Index (NVI)? \n\nThe negative volume index (NVI) is a technical indication line that integrates volume and price to graphically show how price movements are affected by down volume days. \n\n### Key Takeaways\n\n * The negative volume index integrates volume and price to graphically show how price movements are affected by down volume days.\n * The negative volume index trendlines can potentially be the best trendlines for following mainstream, smart money movements typically characterized by institutional investors.\n * NVI can be used in conjunction with the positive volume index (PVI) to see how price is being influenced by volume.\n\n## Understanding Negative Volume Index (NVI) \n\nThe negative volume index (NVI) can be used with the (PVI). Both indexes were first developed by Paul Dysart in the 1930s and gained popularity in the 1970s after being spotlighted in Norman Fosback’s book entitled \"Stock Market Logic.\" \n\nThe positive and negative volume indexes are trendlines that can help an investor follow how a security’s price is changing with the effects of volume. PVI and NVI trendlines are typically available through advanced technical charting software programs like MetaStock and EquityFeedWorkstation. Trendlines are usually added below a pattern similar to the visualization of volume bar charts. \n\nNegative volume index trendlines can potentially be the best trendlines for following mainstream, smart money movements typically characterized by . Positive volume index trendlines are usually more broadly associated with high volume market trending effects, which are known to be more heavily influenced by both smart money and noise traders. \n\nNVI can be useful after a price comes down from high-volume trading. Low volume days can show how institutional money and mainstream investors are trading a security. Generally, it is best to follow both the NVI and PVI together, as overall they represent how price is being influenced by volume. \n\n## NVI Calculations \n\nCalculation of the NVI depends on how for a single day compares with the previous day’s trading volume. \n\nNVI will only change when the volume has decreased from one day to the next. Thus, if the current volume is higher, there is no change. If the volume is lower than the previous day then NVI is calculated using the following equation: \n\n\\begin{aligned}&\\text{NVI}_{\\text{t}}=\\frac{(\\text{P}_{\\text{t}}-\\text{P}_{\\text{t}-1})}{\\text{P}_{\\text{t}-1}}\\times\\text{NVI}_{\\text{t}-1}\\\\\\&\\textbf{where:}\\\\\\&\\text{NVI}_{\\text{t}}=\\text{Negative volume index at time t}\\\\\\&\\text{P}_{\\text{t}}=\\text{Price or the index level at time t}\\end{aligned}\n\n_Investopedia does not provide tax, investment, or financial services and advice. The information is presented without consideration of the investment objectives, risk tolerance, or financial circumstances of any specific investor and might not be suitable for all investors. Investing involves risk, including the possible loss of principal._"}
{"fic_id": "fic_article_2735", "name": "Economic Order Quantity (EOQ)", "short_description": "Calculates the Economic Order Quantity (EOQ), the optimal number of units a company should order to minimize total inventory costs, considering annual demand, order cost per order, and holding cost per unit per year.", "domain": "corporate_finance", "topic": "inventory_management", "topic_extension": true, "version": "v2", "source_meta": {"function_id": "article-2735", "source": "FinanceReasoning-test-1114", "question_id": "test-1108", "difficulty": 2.4849066497880004, "level": "medium", "execution_smoke_ok": true, "execution_autofix_applied": false, "normalization_version": "ast_v1_docstring_strip", "code_sanity_ok": true, "ast_exact_hash": "7c73708e06e00517b76645cdd89f0efebfea168c4aa35f2f59fafad2689190df", "is_duplicate_kernel": false, "duplicate_of": null}, "selection_hints": ["Economic Order Quantity", "EOQ", "inventory management", "optimal order quantity", "ordering costs", "holding costs", "inventory optimization"], "semantic_hints": [{"id": "demand_periodicity", "ambiguity_type": "time_basis", "trigger_signal": "demand period not explicitly stated as annual", "clarification_question": "Is the provided demand figure on an annual basis, or for a shorter period (e.g., monthly)? The EOQ formula typically assumes annual demand.", "options": [{"label": "Annual demand (DEFAULT)", "value": "annual", "is_default": true}, {"label": "Monthly demand (system will annualize before computation)", "value": "monthly_to_annualize", "is_default": false}], "i_level": "soft", "assumption_if_not_clarified": "The provided demand is on an annual basis.", "impact_scope": "input_binding"}], "inputs": [{"name": "demand", "type": "number", "required": true, "description": "The total demand for the product in units, typically on an annual basis.", "unit": null, "aliases": []}, {"name": "order_cost", "type": "number", "required": true, "description": "The fixed cost incurred each time an order is placed (per purchase order).", "unit": null, "aliases": []}, {"name": "holding_cost", "type": "number", "required": true, "description": "The cost to hold one unit of the product in inventory for one year.", "unit": null, "aliases": []}], "output": {"name": "eoq", "type": "number", "unit": null, "description": "The Economic Order Quantity, representing the optimal order size to minimize total inventory costs."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    demand = inputs['demand']\n    order_cost = inputs['order_cost']\n    holding_cost = inputs['holding_cost']\n    eoq = (2 * demand * order_cost / holding_cost) ** 0.5\n    return eoq", "deterministic": true}, "diagnostic_checks": [{"rule_id": "input_demand_type_check", "name": "Demand input must be a number", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "not isinstance(inputs.get('demand'), (int, float))", "applies_to": ["demand"], "description": "The 'demand' input must be a numerical value."}, {"rule_id": "input_order_cost_type_check", "name": "Order Cost input must be a number", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "not isinstance(inputs.get('order_cost'), (int, float))", "applies_to": ["order_cost"], "description": "The 'order_cost' input must be a numerical value."}, {"rule_id": "input_holding_cost_type_check", "name": "Holding Cost input must be a number", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "not isinstance(inputs.get('holding_cost'), (int, float))", "applies_to": ["holding_cost"], "description": "The 'holding_cost' input must be a numerical value."}, {"rule_id": "demand_positive_check", "name": "Demand must be positive", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['demand'] <= 0", "applies_to": ["demand"], "description": "The 'demand' for the product must be a positive value to calculate a meaningful EOQ."}, {"rule_id": "order_cost_positive_check", "name": "Order Cost must be positive", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['order_cost'] <= 0", "applies_to": ["order_cost"], "description": "The 'order_cost' must be a positive value."}, {"rule_id": "holding_cost_positive_check", "name": "Holding Cost must be positive", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['holding_cost'] <= 0", "applies_to": ["holding_cost"], "description": "The 'holding_cost' must be a positive value to avoid division by zero and ensure a meaningful EOQ."}], "execution_smoke_test": {"ok": true, "error": null, "autofix_applied": false, "lint_fixes": [], "effective_code": "def compute(inputs):\n    demand = inputs['demand']\n    order_cost = inputs['order_cost']\n    holding_cost = inputs['holding_cost']\n    eoq = (2 * demand * order_cost / holding_cost) ** 0.5\n    return eoq"}, "article_title": "Economic Order Quantity (EOQ)", "article_doc_id": 5479, "article_content_excerpt": "# Economic Order Quantity: What Does It Mean and Who Is It Important for?\n\n## What Is Economic Order Quantity (EOQ)? \n\nEconomic order quantity (EOQ) is the ideal quantity of units a company should purchase to meet demand while minimizing costs such as holding costs, shortage costs, and order costs. This production-scheduling model was developed in 1913 by Ford W. Harris and has been refined over time. The economic order quantity formula assumes that demand, ordering, and holding costs all remain constant. \n\n### Key Takeaways\n\n * The economic order quantity (EOQ) is a company's optimal order quantity that meets demand while minimizing its total costs related to ordering, receiving, and holding inventory.\n * The EOQ formula is best applied in situations where demand, ordering, and holding costs remain constant over time.\n * One of the important limitations of the economic order quantity is that it assumes the demand for the company’s products is constant over time.\n\n:max_bytes\\(150000\\):strip_icc\\(\\)/Term-Definitions_economicorderquantity-11c47d27b8094534a3c848e9e40fdbbd.png)\n\nInvestopedia / Jessica Olah\n\n## Formula for Economic Order Quantity (EOQ) \n\nThe formula for EOQ is: \n\n> \\begin{aligned} &Q = \\sqrt{ \\frac{2DS}{H} }\\\\\\ &\\textbf{where:}\\\\\\ &Q=\\text{EOQ units}\\\\\\ &D=\\text{Demand in units (typically on an annual basis)}\\\\\\ &S=\\text{Order cost (per purchase order)}\\\\\\ &H=\\text{Holding costs (per unit, per year)}\\\\\\ \\end{aligned}\n\n## What Economic Order Quantity (EOQ) Can Tell You \n\nThe goal of the EOQ formula is to identify the optimal number of product units to order. If achieved, a company can minimize its costs for buying, delivering, and storing units. The EOQ formula can be modified to determine different production levels or order intervals, and corporations with large and high variable costs use an algorithm in their computer software to determine EOQ. \n\nEOQ is an important tool. The formula can help a company control the amount of cash tied up in the inventory balance. \n\nFor many companies, inventory is its largest asset other than its human resources, and these businesses must carry sufficient inventory to meet the needs of customers. If EOQ can help minimize the level of inventory, the cash savings can be used for some other business purpose or investment. \n\nThe EOQ formula of a company. When inventory falls to a certain level, the EOQ formula, if applied to business processes, triggers the need to place an order for more units. \n\nBy determining a reorder point, the business avoids running out of inventory and can continue to fill customer orders. If the company runs out of inventory, there is a shortage cost, which is the revenue lost because the company has insufficient inventory to fill an order. An inventory shortage may also mean the company loses the customer or the client will order less in the future. \n\n## Example of How to Use Economic Order Quantity (EOQ) \n\nEOQ takes into account the timing of reordering, the cost incurred to place an order, and the cost to store merchandise. If a company is constantly placing small orders to maintain a specific inventory level, the ordering costs are higher, and there is a need for additional storage space. \n\nAssume, for example, that a retail clothing shop carries a line of men’s jeans, and the shop sells 1,000 pairs of jeans each year. It costs the company $5 per year to hold a pair of jeans in inventory, and the fixed cost to place an order is $2. \n\nThe EOQ formula is the square root of (2 x 1,000 pairs x $2 order cost) / ($5 holding cost) or 28.3 with rounding. The ideal order size to minimize costs and meet customer demand is slightly more than 28 pairs of jeans. A more complex portion of the EOQ formula provides the reorder point. \n\n## Limitations of Economic Order Quantity (EOQ) \n\nThe EOQ formula assumes that consumer demand is constant. The calculation also assumes that both ordering and holding costs remain constant. \n\nThis fact makes it difficult or impossible fo\n...[truncated]"}
