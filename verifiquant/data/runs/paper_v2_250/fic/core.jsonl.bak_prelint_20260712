mes interest is compounded per year.", "unit": null, "aliases": []}, {"name": "years", "type": "number", "required": true, "description": "The period in years until the future value is received.", "unit": null, "aliases": []}], "output": {"name": "present_value", "type": "number", "unit": "currency", "description": "The present value of the future sum."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    future_value = inputs['future_value']\n    interest_rate = inputs['interest_rate']\n    compounding_periods_per_year = inputs['compounding_periods_per_year']\n    years = inputs['years']\n    present_value = future_value / (1 + interest_rate / compounding_periods_per_year) ** (compounding_periods_per_year * years)\n    return present_value", "deterministic": true}, "diagnostic_checks": [{"rule_id": "fv_non_negative", "name": "Future Value Non-Negative", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['future_value'] < 0", "applies_to": [], "description": "The future value must be a non-negative amount."}, {"rule_id": "ir_non_negative", "name": "Interest Rate Non-Negative", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['interest_rate'] < 0", "applies_to": [], "description": "The interest rate cannot be negative."}, {"rule_id": "cpy_positive", "name": "Compounding Periods Positive", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['compounding_periods_per_year'] <= 0", "applies_to": [], "description": "The number of compounding periods per year must be a positive integer."}, {"rule_id": "years_non_negative", "name": "Years Non-Negative", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['years'] < 0", "app