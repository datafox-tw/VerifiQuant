value": "months", "is_default": false, "transform_spec": {"patch_type": "result_postprocess", "result_expr": "(result + principal) ** (1/12) - principal", "max_expr_nodes": 17, "invariant": "result_new == (result_old + principal)**(1/12) - principal", "affected_inputs": ["principal"]}}], "i_level": "soft", "assumption_if_not_clarified": "Time is provided in years.", "impact_scope": "output_interpretation"}], "inputs": [{"name": "principal", "type": "number", "required": true, "description": "The principal amount. The initial sum of money borrowed or invested.", "unit": "$", "aliases": ["initial_amount", "capital"]}, {"name": "rate", "type": "number", "required": true, "description": "The annual interest rate expressed as a decimal (e.g., 0.05 for 5%).", "unit": null, "aliases": ["annual_rate", "interest_rate"]}, {"name": "time", "type": "number", "required": true, "description": "The total time duration for which the interest is calculated, in years.", "unit": "years", "aliases": ["duration_years", "investment_period"]}, {"name": "compounding_frequency", "type": "integer", "required": true, "description": "The number of times the interest is compounded per year.", "unit": "times/year", "aliases": ["frequency_per_year", "compound_periods"]}], "output": {"name": "compound_interest", "type": "number", "unit": "$", "description": "The calculated compound interest."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    principal = inputs['principal']\n    rate = inputs['rate']\n    time = inputs['time']\n    compounding_frequency = inputs['compounding_frequency']\n    compound_interest = principal * (1 + rate / compounding_frequency) ** (compounding_frequency * time) - principal\n    return compound_interest", "deterministic": true}, "diagnostic_checks": [{"rule_id": "ci001", "name": "Principal Type Check", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs.get('principal'), (int, float))", "applies_to": ["principal"], "description": "The 'principal' input must be a number (integer or float)."}, {"rule_id": "ci002", "name": "Rate Type Check", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs.get('rate'), (int, float))", "applies_to": ["rate"], "description": "The 'rate' input must be a number (integer or float)."}, {"rule_id": "ci003", "name": "Time Type Check", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs.get('time'), (int, float))", "applies_to": ["time"], "description": "The 'time' input must be a number (integer or float)."}, {"rule_id": "ci004", "name": "Compounding Frequency Type Check", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs.get('compounding_frequency'), int)", "applies_to": ["compounding_frequency"], "description": "The 'compounding_frequency' input must be an integer."}, {"rule_id": "ci005", "name": "Principal Positive Check", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['principal'] <= 0", "applies_to": ["principal"], "description": "The principal amount must be positive."}, {"rule_id": "ci006", "name": "Rate Non-Negative Check", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['rate'] < 0", "applies_to": ["rate"], "description": "The annual interest rate cannot be negative."}, {"rule_id": "ci007", "name": "Time Positive Check", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['time'] <= 0", "applies_to": ["time"], "description": "The time duration must be positive."}, {"rule_id": "ci008", "name": "Compounding Frequency Positive Check", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['compounding_frequency'] <= 0", "applies_to": ["compounding_frequency"], "description": "The compounding frequency must be a positive integer."}], "execution_smoke_test": {"ok": true, "error": null, "autofix_applied": false, "lint_fixes": [], "effective_code": "def compute(inputs):\n    principal = inputs['principal']\n    rate = inputs['rate']\n    time = inputs['time']\n    compounding_frequency = inputs['compounding_frequency']\n    compound_interest = principal * (1 + rate / compounding_frequency) ** (compounding_frequency * time) - principal\n    return compound_interest"}, "article_title": "Interest", "article_doc_id": 700, "article_content_excerpt": "# Interest: Definition and Types of Fees for Borrowing Money\n\nDefinition\n\nInterest is a charge for borrowing money, typically expressed as a percentage of the principal amount borrowed. For lenders, it's the compensation for temporarily parting with their funds.\n\nInterest is the charge for borrowing money. Interest expense or revenue is often expressed as a dollar amount, while the interest rate used to calculate interest is typically described as an annual percentage rate (APR). It's also the amount of money a lender or financial institution receives for lending out money. \n\nInterest can also refer to the amount of ownership a stockholder has in a company, usually expressed as a percentage. \n\n### Key Takeaways\n\n * Interest is the monetary charge for borrowing money—generally expressed as a percentage, such as an annual percentage rate (APR).\n * Lenders may earn interest for using their funds or paid by borrowers for using those funds.\n * Interest is often considered simple interest (based on the principal amount) or compound interest (based on principal and previously earned interest).\n * Interest is often associated with credit cards, mortgages, car loans, private loans, savings accounts, or penalty assessments.\n * Interest is highly dependent on macroeconomic policy dictated by the Federal Reserve's Federal funds rate.\n\n:max_bytes\\(150000\\):strip_icc\\(\\)/interest.asp-final-c3fdffd368294a708ea21ff11cd4df06.png)\n\nInvestopedia / NoNo Flores\n\n## Understanding Interest \n\nInterest compensates one party for incurring risk and sacrificing the opportunity to use funds while penalizing another party for using someone else's funds. The person temporarily parting ways with their money is entitled to compensation, and the person temporarily using those funds is often required to pay this compensation. \n\nWhen you leave money in your , your account is credited interest. This is because the bank uses your money and loans it out to other clients, resulting in you earning interest revenue. \n\nThe amount of interest a person must pay is often tied to their creditworthiness, the length of the loan, or the nature of the loan. All else being equal, interest and interest rates are higher when there is greater risk; as the lender faces a greater risk of the borrower being unable to make their payments, the lender may charge more interest to incentivize them to make the loan. \n\n### Fast Fact: \n\nAPR includes the loan's interest rate, as well as other charges, such as origination fees, closing costs, or .\n\n## History of Interest Rates \n\nThe concept of interest—the cost of borrowing money—is commonplace today. However, the acceptability of interest only began during the Renaissance. \n\nInterest is an ancient practice, but social norms from ancient Mediterranean and Middle Eastern civilizations to Medieval Europe regarded charging interest on loans as a sin or usury. Before Christianity, the Greeks and Romans understood that making money off money itself was unnatural, as Aristotle argued in his _Politics_. Aristotle separated two kinds of moneymaking, which are crucial for almost two millennia that followed him across Europe and the Middle East: \n\n * **Proper economic relations (_oikonomikē_)**: These belong to the needs of household management (English gets the word \"economics\" from the Greek term). Wealth is a means toward another end (food, shelter, property, the good life, etc.).\n * **Unnatural love of money (_chrēmatistikē_)**: Here, wealth acquisition becomes its own end through trade and using money to make more money. Aristotle viewed this form of moneymaking as unnatural and harmful to those who practiced it. In his _Nicomachean Ethics_ , he suggested it was a life so foolhardy that it deserved no serious discussion when describing flourishing lives. He was particularly critical of usury (lending money at interest), which he saw as the most unnatural form of _chrēmatistikē_. Importantly, usury meant _any_ interest earned, not excessive interest\n...[truncated]"}
