lue": "consistent_period", "is_default": true}, {"label": "No, revenue needs to be adjusted to match period_days", "value": "inconsistent_period", "is_default": false}], "i_level": "soft", "assumption_if_not_clarified": "Revenue and period_days are consistent.", "impact_scope": "input_binding"}], "inputs": [{"name": "beginning_ar", "type": "number", "required": true, "description": "The accounts receivable value at the beginning of the period.", "unit": null, "aliases": []}, {"name": "ending_ar", "type": "number", "required": true, "description": "The accounts receivable value at the end of the period.", "unit": null, "aliases": []}, {"name": "revenue", "type": "number", "required": true, "description": "The total revenue for the period.", "unit": null, "aliases": []}, {"name": "period_days", "type": "integer", "required": true, "description": "The number of days in the period (e.g., 365 for a year).", "unit": "days", "aliases": []}], "output": {"name": "dso", "type": "number", "unit": "days", "description": "The Days Sales Outstanding, representing the average number of days to collect receivables."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    beginning_ar = inputs['beginning_ar']\n    ending_ar = inputs['ending_ar']\n    revenue = inputs['revenue']\n    period_days = inputs['period_days']\n    average_ar = 0.5 * (beginning_ar + ending_ar)\n    if revenue == 0:\n        return float('inf')\n    dso = average_ar / (revenue / period_days)\n    return round(dso, 2)", "deterministic": true}, "diagnostic_checks": [{"rule_id": "ar_non_negative", "name": "Accounts Receivable Non-Negative", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['beginning_ar'] < 0 or inputs['ending_ar'] < 0", "applies_to": ["beginning_ar", "ending_ar"], "description": "Beginning and ending accounts receivable must be non-negative values."}, {"rule_id": "revenue_non