_workers", "type": "integer", "required": true, "description": "The number of discouraged workers not currently seeking work.", "unit": null, "aliases": []}, {"name": "labor_force_without_discouraged", "type": "integer", "required": true, "description": "The total labor force excluding discouraged workers.", "unit": null, "aliases": []}], "output": {"name": "u4_rate", "type": "number", "unit": "%", "description": "The U-4 unemployment rate as a percentage."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    unemployed = inputs['unemployed']\n    discouraged_workers = inputs['discouraged_workers']\n    labor_force_without_discouraged = inputs['labor_force_without_discouraged']\n    total_labor_force = labor_force_without_discouraged + discouraged_workers\n    if total_labor_force == 0:\n        return 0.0\n    u4_rate = (unemployed + discouraged_workers) / total_labor_force * 100\n    return u4_rate", "deterministic": true}, "diagnostic_checks": [{"rule_id": "unemployed_type_check", "name": "Unemployed input must be an integer", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "not isinstance(inputs['unemployed'], int)", "applies_to": ["unemployed"], "description": "The 'unemployed' input must be an integer representing a count."}, {"rule_id": "discouraged_workers_type_check", "name": "Discouraged workers input must be an integer", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "not isinstance(inputs['discouraged_workers'], int)", "applies_to": ["discouraged_workers"], "description": "The 'discouraged_workers' input must be an integer representing a count."}, {"rule_id": "labor_force_without_discouraged_type_check", "name": "Labor force without discouraged input must be an integer", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "not isinstance(inputs['labor_force_without_discouraged'], int)", "applies_to": ["labor_force_without_discouraged"], "description": "The 'labor_force_without_discouraged' input must be an integer representing a count."}, {"rule_id": "input_non_negative", "name": "All inputs must be non-negative", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['unemployed'] < 0 or inputs['discouraged_workers'] < 0 or inputs['labor_force_without_discouraged'] < 0", "applies_to": ["unemployed", "discouraged_workers", "labor_force_without_discouraged"], "description": "The number of unemployed, discouraged workers, and labor force without discouraged workers cannot be negative."}, {"rule_id": "total_labor_force_positive", "name": "Total labor force must be positive", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "(inputs['labor_force_without_discouraged'] + inputs['discouraged_workers']) <= 0", "applies_to": ["discouraged_workers", "labor_force_without_discouraged"], "description": "The sum of labor force without discouraged workers and discouraged workers must be greater than zero to calculate the U-4 rate, avoiding division by zero."}, {"rule_id": "u4_rate_bounds", "name": "U-4 rate must be between 0% and 100%", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "compute(inputs) < 0 or compute(inputs) > 100", "applies_to": [], "description": "The calculated U-4 unemployment rate should logically fall between 0% and 100%."}], "execution_smoke_test": {"ok": true, "error": null, "autofix_applied": false, "lint_fixes": [], "effective_code": "def compute(inputs):\n    unemployed = inputs['unemployed']\n    discouraged_workers = inputs['discouraged_workers']\n    labor_force_without_discouraged = inputs['labor_force_without_discouraged']\n    total_labor_force = labor_force_without_discouraged + discouraged_workers\n    if total_labor_force == 0:\n        return 0.0\n    u4_rate = (unemployed + discouraged_workers) / total_labor_force * 100\n    return u4_rate"}, "article_title": "Discouraged Worker", "article_doc_id": 3340, "article_content_excerpt": "# Discouraged Worker: Definition, Causes, vs. Unemployed\n\n## What Is a Discouraged Worker? \n\nA discouraged worker is a person who is eligible for employment and can work, but who is currently unemployed and has not attempted to find employment in the last four weeks. Discouraged workers usually have given up on searching for a job because they found no suitable employment options or failed to secure a job when they applied. \n\n### Key Takeaways\n\n * Discouraged workers are workers who have stopped looking for work because they found no suitable employment options or failed to be shortlisted when applying for a job.\n * The causes for worker discouragement are complex and varied.\n * Discouraged workers are not included in the headline unemployment number. Instead, they are included in the U-4, U-5, and U-6 unemployment measures.\n * The U-4 rate is calculated by dividing the sum of unemployed and discouraged workers by the total labor force, including discouraged workers.\n * Policymakers use underutilization of labor rates, such as U-4, to create plans that help discouraged workers get back to work and incentivize companies for hiring them.\n\n## Understanding Discouraged Workers \n\nThe U.S. Department of Labor’s defines discouraged workers as “those persons not in the labor force who want and are available for work, and who have looked for a job sometime in the prior 12 months, but were not counted as unemployed because they had not searched for work in the four weeks preceding the survey.” The BLS adds that “discouraged workers were not currently looking for work specifically because they believed no jobs were available for them or there were none for which they would qualify.”\n\nAs discouraged workers are no longer looking for employment, they are not counted as active in the labor force. This means that the headline , which is based solely on the active labor force number, in the country.\n\n### Causes for Worker Discouragement \n\nThe causes for worker discouragement are complex and varied. In some cases, workers fall out of the workforce because they are not equipped to deal with technological change in their workplace. An example of this occurred during the , when the manufacturing sector shed senior staff unable to work on the new computer numeric control (CNC) machines, used for cutting wood and other hard materials, according to a report by _The Washington Post_.\n\nNick Eberstadt of the American Enterprise Institute (AEI) has blamed the “flight from work” on a lack of supply of skilled, able, and willing workers and an increasing reliance on . His theory is backed by Alan Krueger’s 2016 research, which found that self-reported pain and disability insurance was higher among discouraged workers.\n\nOther possible reasons for discouraged workers include restrictions that limit employment options for formerly incarcerated individuals and jobs that are perceived as being inaccessible to a specific gender.\n\n### 369,000\n\nThe number of discouraged workers in the U.S. in June 2024, according to the Bureau of Labor Statistics (BLS).\n\n## BLS Accounting for Discouraged Workers \n\nTo better analyze unemployment in the U.S., the BLS created . U-4, U-5, and U-6 capture discouraged workers.\n\n * U-4 equals the total number of unemployed people, plus discouraged workers.\n * U-5 equals the total number of unemployed people, discouraged workers, and other marginally attached workers.\n * U-6 equals the total number of unemployed people, all marginally attached workers, plus people employed part-time who are seeking full-time employment.\n\nFrom the second quarter of 2023 through the first quarter of 2024, the U-4 rate, seasonally adjusted, was 3.9%, just a shade higher than the headline, or official, unemployment rate of 3.7%.\n\nIn spite of the pandemic's impact on the economy, the current U-4 number is not as bad as the 2009 annual average, which stood at 9.7% in the throes of the Great Recession.\n\n## Helping the Discouraged \n\nThe U-4 rate helps to quantif\n...[truncated]"}
