ame": "beta", "type": "number", "unit": null, "description": "The calculated beta value of the asset, indicating its volatility relative to the market."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    asset_returns = inputs['asset_returns']\n    market_returns = inputs['market_returns']\n    if len(asset_returns) != len(market_returns):\n        raise ValueError('Asset and market return lists must have the same length.')\n    if len(asset_returns) < 2:\n        raise ValueError('Requires at least two data points in asset_returns and market_returns.')\n    mean_asset = sum(asset_returns) / len(asset_returns)\n    mean_market = sum(market_returns) / len(market_returns)\n    covariance = sum(((a - mean_asset) * (m - mean_market) for a, m in zip(asset_returns, market_returns))) / (len(asset_returns) - 1)\n    market_variance = sum(((m - mean_market) ** 2 for m in market_returns)) / (len(market_returns) - 1)\n    if market_variance == 0:\n        raise ValueError('Market variance cannot be zero, as all market returns are identical.')\n    beta = covariance / market_variance\n    return beta", "deterministic": true}, "diagnostic_checks": [{"rule_id": "asset_returns_is_list_f", "name": "Asset Returns Input Type Check", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['asset_returns'], list)", "applies_to": ["asset_returns"], "description": "The 'asset_returns' input must be a list."}, {"rule_id": "market_returns_is_list_f", "name": "Market Returns Input Type Check", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "isinstance(inputs['market_returns'], list)", "applies_to": ["market_returns"], "description": "The 'market_returns' input must be a list."}, {"rule_id": "asset_returns_elements_numerical_f", "name": "Asset Returns Elements Numerical Check", "check_type": 