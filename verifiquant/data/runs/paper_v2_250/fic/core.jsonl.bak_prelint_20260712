n    year = inputs['year']\n    depreciable_base = asset_value - salvage_value\n    sum_of_years = sum(range(1, useful_life_years + 1))\n    inverse_year_number = useful_life_years - year + 1\n    annual_depreciation = depreciable_base * (inverse_year_number / sum_of_years)\n    return round(annual_depreciation)", "deterministic": true}, "diagnostic_checks": [{"rule_id": "f_asset_value_type", "name": "Asset Value Type Check", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "not isinstance(inputs.get('asset_value'), (int, float))", "applies_to": ["asset_value"], "description": "Asset value must be a numeric type (integer or float)."}, {"rule_id": "f_salvage_value_type", "name": "Salvage Value Type Check", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "not isinstance(inputs.get('salvage_value'), (int, float))", "applies_to": ["salvage_value"], "description": "Salvage value must be a numeric type (integer or float)."}, {"rule_id": "f_useful_life_years_type", "name": "Useful Life Years Type Check", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "not isinstance(inputs.get('useful_life_years'), int)", "applies_to": ["useful_life_years"], "description": "Useful life in years must be an integer."}, {"rule_id": "f_year_type", "name": "Year Type Check", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "not isinstance(inputs.get('year'), int)", "applies_to": ["year"], "description": "The specific year must be an integer."}, {"rule_id": "e_asset_value_positive", "name": "Asset Value Must Be Positive", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['asset_value'] <= 0", "applies_to": ["asset_value"], "descript