l (e.g., 0.5) or a percentage (e.g., 50%)?", "options": [{"label": "Decimal — DEFAULT", "value": "decimal", "is_default": true}, {"label": "Percent", "value": "percent", "is_default": false, "transform_spec": {"patch_type": "result_postprocess", "result_expr": "result * 100.0", "max_expr_nodes": 6, "invariant": "result_new == result_old * 100.0", "affected_inputs": []}}], "i_level": "soft", "assumption_if_not_clarified": "Decimal", "impact_scope": "output_interpretation"}], "inputs": [{"name": "todays_high", "type": "number", "required": true, "description": "Today's highest price of the security.", "unit": null, "aliases": []}, {"name": "todays_low", "type": "number", "required": true, "description": "Today's lowest price of the security.", "unit": null, "aliases": []}, {"name": "yesterdays_close", "type": "number", "required": true, "description": "Yesterday's closing price of the security.", "unit": null, "aliases": []}, {"name": "ema", "type": "number", "required": true, "description": "Exponential Moving Average of the true range over a past N-day period.", "unit": null, "aliases": []}], "output": {"name": "volatility_ratio", "type": "number", "unit": null, "description": "The calculated volatility ratio using EMA."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    todays_high = inputs['todays_high']\n    todays_low = inputs['todays_low']\n    yesterdays_close = inputs['yesterdays_close']\n    ema = inputs['ema']\n    todays_true_range = max(todays_high - todays_low, abs(todays_high - yesterdays_close), abs(yesterdays_close - todays_low))\n    if ema <= 0:\n        raise ValueError('EMA must be a positive number.')\n    volatility_ratio = todays_true_range / ema\n    return volatility_ratio", "deterministic": true}, "diagnostic_checks": [{"rule_id": "input_presence", "name": "All required inputs must be present", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violati