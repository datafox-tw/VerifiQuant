 Default is 'call'.", "unit": null, "aliases": ["type", "call_or_put"]}], "output": {"name": "option_price", "type": "number", "unit": "dollars", "description": "The theoretical price of the option."}, "execution": {"language": "python", "entrypoint": "compute", "code": "import math\nfrom scipy.stats import norm\n\ndef compute(inputs):\n    stock_price = inputs['stock_price']\n    strike_price = inputs['strike_price']\n    time_to_expiration = inputs['time_to_expiration']\n    risk_free_rate = inputs['risk_free_rate']\n    volatility = inputs['volatility']\n    option_type = inputs.get('option_type', 'call')\n    if option_type not in ['call', 'put']:\n        raise ValueError(\"Option type must be either 'call' or 'put'.\")\n    d1 = (math.log(stock_price / strike_price) + (risk_free_rate + 0.5 * volatility ** 2) * time_to_expiration) / (volatility * math.sqrt(time_to_expiration))\n    d2 = d1 - volatility * math.sqrt(time_to_expiration)\n    if option_type == 'call':\n        option_price = stock_price * norm.cdf(d1) - strike_price * math.exp(-risk_free_rate * time_to_expiration) * norm.cdf(d2)\n    else:\n        option_price = strike_price * math.exp(-risk_free_rate * time_to_expiration) * norm.cdf(-d2) - stock_price * norm.cdf(-d1)\n    return round(option_price, 2)", "deterministic": true}, "diagnostic_checks": [{"rule_id": "bs_input_missing_stock_price", "name": "Stock price required", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "inputs.get('stock_price') is None", "applies_to": ["stock_price"], "description": "The current stock price is a required input for the Black-Scholes model."}, {"rule_id": "bs_input_missing_strike_price", "name": "Strike price required", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "inputs.get('strike_price') is None", "applies_to": ["strike_price"], "description": "The option's strike price is a required input for the Black-Scholes model."}, {"rule_id": "bs_input_missing_time_to_expiration", "name": "Time to expiration required", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "inputs.get('time_to_expiration') is None", "applies_to": ["time_to_expiration"], "description": "The time remaining until the option expires is a required input."}, {"rule_id": "bs_input_missing_risk_free_rate", "name": "Risk-free rate required", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "inputs.get('risk_free_rate') is None", "applies_to": ["risk_free_rate"], "description": "The risk-free interest rate is a required input for discounting future values."}, {"rule_id": "bs_input_missing_volatility", "name": "Volatility required", "check_type": "deterministic", "diagnostic_type": "F", "severity": "error", "predicate_mode": "violation", "expression": "inputs.get('volatility') is None", "applies_to": ["volatility"], "description": "The volatility of the underlying asset is a critical required input."}, {"rule_id": "bs_invalid_option_type", "name": "Invalid option type", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs.get('option_type') not in ['call', 'put'] and inputs.get('option_type') is not None", "applies_to": ["option_type"], "description": "The option type must be either 'call' or 'put'."}, {"rule_id": "bs_non_positive_financial_values", "name": "Non-positive financial inputs", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs.get('stock_price', 0) <= 0 or inputs.get('strike_price', 0) <= 0 or inputs.get('time_to_expiration', 0) <= 0 or inputs.get('volatility', 0) <= 0", "applies_to": ["stock_price", "strike_price", "time_to_expiration", "volatility"], "descript