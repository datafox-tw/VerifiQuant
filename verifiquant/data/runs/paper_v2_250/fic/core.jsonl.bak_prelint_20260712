lt": false}], "i_level": "soft", "assumption_if_not_clarified": "Annual payment", "impact_scope": "output_interpretation"}, {"id": "transaction_perspective", "ambiguity_type": "directionality", "trigger_signal": "total value is a monetary amount without explicit direction (e.g., buyer's cost vs. seller's revenue)", "clarification_question": "Should the 'total_value_paid' be from the BUYER's perspective (total cost) or the SELLER's perspective (total revenue)?", "options": [{"label": "Buyer's perspective (total cost) - DEFAULT", "value": "buyer_cost", "is_default": true}, {"label": "Seller's perspective (total revenue)", "value": "seller_revenue", "is_default": false, "transform_spec": {"patch_type": "result_postprocess", "result_expr": "-result", "max_expr_nodes": 5, "invariant": "result_new == -result_old", "affected_inputs": []}}], "i_level": "soft", "assumption_if_not_clarified": "Buyer's perspective (total cost)", "impact_scope": "output_interpretation"}, {"id": "life_expectancy_basis", "ambiguity_type": "methodology", "trigger_signal": "life expectancy provided without explicit methodology for calculation", "clarification_question": "Is 'life_expectancy_years' based on average demographic data or a specific actuarial calculation?", "options": [{"label": "Average demographic data - DEFAULT", "value": "average_demographic", "is_default": true}, {"label": "Actuarial calculation", "value": "actuarial_calculation", "is_default": false}], "i_level": "soft", "assumption_if_not_clarified": "Average demographic data", "impact_scope": "input_binding"}], "inputs": [{"name": "occupied_value", "type": "number", "required": true, "description": "The occupied value of the property, which is the discounted value based on the seller's age.", "unit": "currency", "aliases": []}, {"name": "down_payment_percentage", "type": "number", "required": true, "description": "The percentage of the occupied value that is paid as a down payment.", "unit": "percent", "aliases": []}, {"name": "life_expectancy_years", "type": "integer", "required": true, "description": "The expected remaining years of life for the seller.", "unit": null, "aliases": []}, {"name": "annual_cash_installment", "type": "number", "required": true, "description": "The annual cash installment agreed upon in the contract.", "unit": "currency", "aliases": []}], "output": {"name": "total_value_paid", "type": "number", "unit": "currency", "description": "The total value paid by the buyer including the down payment and expected cash installments."}, "execution": {"language": "python", "entrypoint": "compute", "code": "def compute(inputs):\n    occupied_value = inputs['occupied_value']\n    down_payment_percentage = inputs['down_payment_percentage']\n    life_expectancy_years = inputs['life_expectancy_years']\n    annual_cash_installment = inputs['annual_cash_installment']\n    down_payment = occupied_value * (down_payment_percentage / 100)\n    total_installments = life_expectancy_years * annual_cash_installment\n    total_value_paid = down_payment + total_installments\n    return round(total_value_paid)", "deterministic": true}, "diagnostic_checks": [{"rule_id": "e_occupied_value_positive", "name": "Occupied Value Positive Check", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['occupied_value'] <= 0", "applies_to": ["occupied_value"], "description": "The occupied value of the property must be a positive number."}, {"rule_id": "e_down_payment_percentage_range", "name": "Down Payment Percentage Range Check", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "not (0 <= inputs['down_payment_percentage'] <= 100)", "applies_to": ["down_payment_percentage"], "description": "The down payment percentage must be between 0 and 100 (inclusive)."}, {"rule_id": "e_life_expectancy_positive", "name": "Life Expectancy Positive Check", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['life_expectancy_years'] <= 0", "applies_to": ["life_expectancy_years"], "description": "The expected remaining life of the seller must be a positive number of years."}, {"rule_id": "e_annual_cash_installment_non_negative", "name": "Annual Cash Installment Non-Negative Check", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "inputs['annual_cash_installment'] < 0", "applies_to": ["annual_cash_installment"], "description": "The annual cash installment must be zero or a positive amount."}, {"rule_id": "e_life_expectancy_plausible_upper_bound", "name": "Life Expectancy Plausible Upper Bound Check", "check_type": "deterministic", "diagnostic_type": "E", "severity": "alert", "predicate_mode": "violation", "expression": "inputs['life_expectancy_years'] > 50", "applies_to": ["life_expectancy_years"], "description": "A life expectancy exceeding 50 years is unusually high for a viager transaction and may indicate an error."}], "execution_smoke_test": {"ok": true, "error": null, "autofix_applied": false, "lint_fixes": [], "effective_code": "def compute(inputs):\n    occupied_value = inputs['occupied_value']\n    down_payment_percentage = inputs['down_payment_percentage']\n    life_expectancy_years = inputs['life_expectancy_years']\n    annual_cash_installment = inputs['annual_cash_installment']\n    down_payment = occupied_value * (down_payment_percentage / 100)\n    total_installments = life_expectancy_years * annual_cash_installment\n    total_value_paid = down_payment + total_installments\n    return round(total_value_paid)"}, "article_title": "Viager", "article_doc_id": 461, "article_content_excerpt": "# Defining and Understanding Viager Transactions\n\n## What Is a Viager? \n\nA \"viager\" is a transaction, popular in France, where the buyer makes a down payment and then a series of payments for as long as the seller is alive. \n\n### Key Takeaways\n\n * A viager is a real estate transaction, popular in France, where the buyer makes a down payment and then a series of payments for as long as the seller is alive.\n * Sellers are often widows or widowers who are in need of a regular source of income after the death of a spouse.\n * For buyers, viagers offer the draw of a home purchase at reduced rates.\n\n## Understanding Viager \n\nEssentially, a \"viager\" is a reverse . For homebuyers, viagers are gambles, while for home-sellers, they offer the security of regular cash installments. A viager is sometimes called a reverse annuity mortgage or a charitable remainder trust. \n\nIn a viager agreement, a person agrees to sell their property to a purchaser in exchange for a down payment, known in France as the \"bouquet,\" and regular cash installments for the rest of their life. Additionally, the seller continues to live in the house for the remainder of their life. It is only when the seller dies that the purchaser is free to take over the property. In essence, the buyer in a viager is wagering on the remaining lifespan of the seller. \n\nIn France, two private parties often negotiate a viager with the help of a lawyer and without the participation of banks or insurance companies. The deal can potentially benefit both parties. For example, sellers receive significant tax breaks. What's more, cash payments are strongly guaranteed. If the buyer , the seller retains the down payment, all of the monthly payments up to that point, and ownership of the property. Sellers are often widows or widowers who are in need of a regular source of income after the death of a spouse. \n\nFor buyers, viagers offer the draw of a home purchase at reduced rates. Viagers use the occupied value rather than the market value, which is often much higher. In addition, buyers pay no interest on the property, and if the seller dies earlier than expected, buyers get an even bigger discount. The risk is that the seller lives longer than expected, in which case the buyer must pay more. The typical viager buyer is a middle-aged person looking to secure a home for retirement. \n\n## Viager Calculation \n\nThe value of a property in a viager is calculated based on the age of the seller, and it is known as the occupied value. The occupied value of a home owned by someone 50 years old will be more than that of a home owned by someone 70 years old. The down payment tends to land at about 30% of the occupied value. Participants calculate the cash installments based on the average life expectancy of the seller. Because of these guidelines, very old sellers would often be better off selling their homes outright and receiving the full market value."}
