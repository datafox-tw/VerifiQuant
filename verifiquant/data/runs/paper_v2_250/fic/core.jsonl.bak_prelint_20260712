']\n    exercise_date = inputs['exercise_date']\n    sale_date = inputs['sale_date']\n\n    def parse_date(date_str):\n        return datetime.strptime(date_str, '%Y-%m-%d')\n    grant_date_parsed = parse_date(grant_date)\n    exercise_date_parsed = parse_date(exercise_date)\n    sale_date_parsed = parse_date(sale_date)\n    sale_condition = (sale_date_parsed - exercise_date_parsed).days > 365\n    grant_condition = (sale_date_parsed - grant_date_parsed).days > 730\n    return sale_condition and grant_condition", "deterministic": true}, "diagnostic_checks": [{"rule_id": "iso_grant_date_format", "name": "Grant Date Format Check", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "try: datetime.strptime(inputs['grant_date'], '%Y-%m-%d'); True; except ValueError: False", "applies_to": [], "description": "The 'grant_date' input must be a valid date string in 'YYYY-MM-DD' format."}, {"rule_id": "iso_exercise_date_format", "name": "Exercise Date Format Check", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "try: datetime.strptime(inputs['exercise_date'], '%Y-%m-%d'); True; except ValueError: False", "applies_to": [], "description": "The 'exercise_date' input must be a valid date string in 'YYYY-MM-DD' format."}, {"rule_id": "iso_sale_date_format", "name": "Sale Date Format Check", "check_type": "normalization", "diagnostic_type": "F", "severity": "error", "predicate_mode": "validity", "expression": "try: datetime.strptime(inputs['sale_date'], '%Y-%m-%d'); True; except ValueError: False", "applies_to": [], "description": "The 'sale_date' input must be a valid date string in 'YYYY-MM-DD' format."}, {"rule_id": "iso_exercise_after_grant", "name": "Exercise Date After Grant Date", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "datetime.strptime(inputs['exercise_date'], '%Y-%m-%d') < datetime.strptime(inputs['grant_date'], '%Y-%m-%d')", "applies_to": [], "description": "The exercise date must be on or after the grant date."}, {"rule_id": "iso_sale_after_exercise", "name": "Sale Date After Exercise Date", "check_type": "deterministic", "diagnostic_type": "E", "severity": "error", "predicate_mode": "violation", "expression": "datetime.strptime(inputs['sale_date'], '%Y-%m-%d') < datetime.strptime(inputs['exercise_date'], '%Y-%m-%d')", "applies_to": [], "description": "The sale date must be on or after the exercise date."}, {"rule_id": "iso_exercise_within_10_years", "name": "Exercise Within 10 Years of Grant", "check_type": "deterministic", "diagnostic_type": "E", "severity": "alert", "predicate_mode": "violation", "expression": "(datetime.strptime(inputs['exercise_date'], '%Y-%m-%d') - datetime.strptime(inputs['grant_date'], '%Y-%m-%d')).days > 365 * 10", "applies_to": [], "description": "Incentive Stock Options (ISOs) typically expire after 10 years; exercising them beyond this period may not be possible or intended."}, {"rule_id": "iso_non_qualifying_alert", "name": "Non-Qualifying Disposition Alert", "check_type": "deterministic", "diagnostic_type": "E", "severity": "alert", "predicate_mode": "violation", "expression": "not compute(inputs)", "applies_to": [], "description": "The provided dates indicate that the ISO sale does not qualify for favorable long-term capital gains tax treatment. Review the holding period requirements."}], "execution_smoke_test": {"ok": false, "error": "__import__ not found", "autofix_applied": false, "lint_fixes": [], "effective_code": "def compute(inputs):\n    from datetime import datetime\n    grant_date = inputs['grant_date']\n    exercise_date = inputs['exercise_date']\n    sale_date = inputs['sale_date']\n\n    def parse_date(date_str):\n        return datetime.strptime(date_str, '%Y-%m-%d')\n    grant_date_parsed = parse_date(grant_date)\n    exercise_date_parsed = parse_date(exercise_date)\n    sale_date_parsed = parse_date(sale_date)\n    sale_condition = (sale_date_parsed - exercise_date_parsed).days > 365\n    grant_condition = (sale_date_parsed - grant_date_parsed).days > 730\n    return sale_condition and grant_condition"}, "article_title": "Incentive Stock Options (ISOs)", "article_doc_id": 583, "article_content_excerpt": "# Incentive Stock Options (ISO): Definition and Meaning\n\nAn incentive stock option (ISO) gives an employee the right to buy shares of company stock at a discounted price. The profit on qualified ISOs is usually taxed at the capital gains rate, not the higher rate for ordinary income. Non-qualified stock options (NSOs) are taxed as ordinary income. Generally, ISOs are awarded only to top management and highly-valued employees. ISOs are also called statutory or qualified stock options.\n\n### Key Takeaways\n\n * Incentive stock options (ISOs) are a popular means of employee compensation for corporate management, granting rights to company stock at a discounted price at a future date.\n * This type of employee stock purchase plan is intended to retain key employees or managers.\n * ISOs require a vesting period of at least two years and a holding period of more than one year before they can be sold.\n * ISOs often have more favorable tax treatment on profits than other types of employee stock purchase plans.\n\n## Understanding Incentive Stock Options (ISOs) \n\nIncentive or are offered by some companies to encourage employees to remain with them long-term and contribute to their growth and development. ISOs are usually issued by publicly traded companies or planning to . They require a plan document that clearly outlines how many options are to be given to specific employees. Those employees must exercise their options within 10 years of receiving them.\n\nOptions can be used to augment salaries or as a reward instead of a traditional salary raise. Stock options, like other benefits, can be used to attract talent, especially if the company cannot afford to pay competitive base salaries. \n\n## How Incentive Stock Options (ISOs) Work \n\nStock options are issued or granted by a company that sets their price, called the “.” This is typically about the value of the shares at the time. \n\nISOs are issued on the grant date, and employees exercise their right to buy the options on the exercise date. Once the options are exercised, the employee can either sell the stock immediately or wait to do so. Unlike nonstatutory options, the offering period for ISOs is always 10 years, after which the options expire.\n\n### Tip: \n\n \n\nISOs can be exercised to purchase shares at a price below the and, thus, provide an immediate profit for the employee.\n\nEmployee stock options () typically have a vesting schedule that must be satisfied before the employee can exercise the options. The standard three-year cliff schedule is used in many cases: the employee becomes fully vested in all the options issued to them at that time. \n\nOther employers use graded vesting. In this system, employees are vested in one-fifth of their options each year, starting in the second year after they were granted. The employee is then fully vested in all options by the sixth year. \n\n## Exercising the Option \n\nWhen the vesting period expires, the employee can purchase the shares at the strike price, that is, “exercise the option.” Then, the employee can sell the stock for its current value, pocketing the difference between the strike price and the sale price as profit. \n\n### Important: \n\nISOs must be held for more than one year from the date of exercise and two years from the time of the grant to qualify for more favorable tax treatment.\n\nOf course, there's no guarantee that the stock price will be higher than the strike price when the options vest. If it's lower, the employee can hold the options until just before the expiration date in the hope that the price will rise. ISOs usually expire after 10 years.\n\nAn ISO may have .**__** These allow the employer to recall the options. For example, the employer might do so if the employee leaves the company for a reason other than death, disability, or retirement or if the company itself becomes financially unable to meet its obligations with the options. \n\n## The Tax Treatment for Incentive Stock Options (ISOs) \n\nISOs are treated more favorably for ta\n...[truncated]"}
